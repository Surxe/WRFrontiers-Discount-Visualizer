---
const baseUrl = import.meta.env.BASE_URL;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Link Style Proposals</title>
		<link rel="stylesheet" href={`${baseUrl}global.css`} />
	</head>
	<body>
		<div class="container">
			<h1>Link Style Proposals</h1>
			<p class="intro">Choose which hyperlink style you prefer for the discount history dates:</p>

			<div class="proposal-section">
				<h2>Proposal 1: Simple Blue Underline</h2>
				<p class="description">Classic blue links with underline on hover</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-1">June 3, 2026</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 2: Accent Color No Underline</h2>
				<p class="description">Accent color links without underline, subtle background on hover</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-2">June 3, 2026</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 3: Bordered Button Style</h2>
				<p class="description">Links with border and background on hover</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-3">June 3, 2026</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 4: Subtle Gray with Accent Hover</h2>
				<p class="description">Gray text that turns accent color on hover</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-4">June 3, 2026</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 5: Bold Accent with Arrow</h2>
				<p class="description">Bold accent color with arrow icon</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-5">June 3, 2026 →</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 6: Pill Badge Style</h2>
				<p class="description">Links styled as pill badges</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-6">June 3, 2026</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 7: Minimalist Dotted Underline</h2>
				<p class="description">Links with dotted underline</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-7">June 3, 2026</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 8: Gradient Text</h2>
				<p class="description">Links with gradient text effect</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-8">June 3, 2026</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 9: Ghost Button Style</h2>
				<p class="description">Links styled as ghost buttons with border</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-9">June 3, 2026</a></p>
				</div>
			</div>

			<div class="proposal-section">
				<h2>Proposal 10: Glowing Effect</h2>
				<p class="description">Links with subtle glow on hover</p>
				<div class="example">
					<p>Last discounted on <a href="#" class="link-style-10">June 3, 2026</a></p>
				</div>
			</div>
		</div>
	</body>
</html>

<style>
	:root {
		--bg-color: #0f1115;
		--sidebar-bg: #161920;
		--sidebar-border: #232733;
		--text-color: #e0e0e0;
		--text-muted: #8b92a5;
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
		--active-bg: rgba(58, 134, 255, 0.1);
	}

	body {
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Montserrat', sans-serif;
		margin: 0;
		padding: 2rem;
		line-height: 1.6;
	}

	.container {
		max-width: 900px;
		margin: 0 auto;
	}

	h1 {
		font-size: 2.5rem;
		margin-bottom: 1rem;
		text-align: center;
		color: var(--text-color);
	}

	.intro {
		text-align: center;
		color: var(--text-muted);
		margin-bottom: 3rem;
		font-size: 1.1rem;
	}

	.proposal-section {
		background-color: var(--sidebar-bg);
		border: 1px solid var(--sidebar-border);
		border-radius: 0.5rem;
		padding: 2rem;
		margin-bottom: 2rem;
	}

	.proposal-section h2 {
		margin-top: 0;
		color: var(--text-color);
		font-size: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.description {
		color: var(--text-muted);
		margin-bottom: 1.5rem;
		font-style: italic;
	}

	.example {
		background-color: rgba(0, 0, 0, 0.2);
		padding: 1.5rem;
		border-radius: 0.25rem;
		font-size: 1.1rem;
	}

	.example p {
		margin: 0;
	}

	/* Proposal 1: Simple Blue Underline */
	.link-style-1 {
		color: #4a90e2;
		text-decoration: none;
		transition: color 0.2s;
	}

	.link-style-1:hover {
		color: #357abd;
		text-decoration: underline;
	}

	/* Proposal 2: Accent Color No Underline */
	.link-style-2 {
		color: var(--accent-color);
		text-decoration: none;
		padding: 2px 6px;
		border-radius: 4px;
		transition: background-color 0.2s, color 0.2s;
	}

	.link-style-2:hover {
		background-color: var(--active-bg);
		color: var(--accent-hover);
	}

	/* Proposal 3: Bordered Button Style */
	.link-style-3 {
		color: var(--text-color);
		text-decoration: none;
		border: 1px solid var(--sidebar-border);
		padding: 4px 12px;
		border-radius: 4px;
		transition: all 0.2s;
		background-color: transparent;
	}

	.link-style-3:hover {
		border-color: var(--accent-color);
		background-color: var(--active-bg);
		color: var(--accent-color);
	}

	/* Proposal 4: Subtle Gray with Accent Hover */
	.link-style-4 {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.link-style-4:hover {
		color: var(--accent-color);
	}

	/* Proposal 5: Bold Accent with Arrow */
	.link-style-5 {
		color: var(--accent-color);
		text-decoration: none;
		font-weight: 700;
		transition: color 0.2s, transform 0.2s;
		display: inline-block;
	}

	.link-style-5:hover {
		color: var(--accent-hover);
		transform: translateX(2px);
	}

	/* Proposal 6: Pill Badge Style */
	.link-style-6 {
		color: var(--text-color);
		text-decoration: none;
		background-color: var(--accent-color);
		padding: 4px 16px;
		border-radius: 999px;
		font-weight: 600;
		font-size: 0.9em;
		transition: all 0.2s;
	}

	.link-style-6:hover {
		background-color: var(--accent-hover);
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(58, 134, 255, 0.4);
	}

	/* Proposal 7: Minimalist Dotted Underline */
	.link-style-7 {
		color: var(--text-color);
		text-decoration: none;
		border-bottom: 1px dotted var(--text-muted);
		transition: border-color 0.2s, color 0.2s;
	}

	.link-style-7:hover {
		border-bottom-color: var(--accent-color);
		color: var(--accent-color);
	}

	/* Proposal 8: Gradient Text */
	.link-style-8 {
		background: linear-gradient(135deg, var(--accent-color), #8a2be2);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		text-decoration: none;
		font-weight: 600;
		transition: opacity 0.2s;
	}

	.link-style-8:hover {
		opacity: 0.8;
	}

	/* Proposal 9: Ghost Button Style */
	.link-style-9 {
		color: var(--accent-color);
		text-decoration: none;
		border: 2px solid var(--accent-color);
		padding: 6px 16px;
		border-radius: 6px;
		font-weight: 600;
		transition: all 0.2s;
		background-color: transparent;
	}

	.link-style-9:hover {
		background-color: var(--accent-color);
		color: white;
		box-shadow: 0 4px 12px rgba(58, 134, 255, 0.3);
	}

	/* Proposal 10: Glowing Effect */
	.link-style-10 {
		color: var(--accent-color);
		text-decoration: none;
		position: relative;
		transition: all 0.2s;
	}

	.link-style-10::before {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 100%;
		height: 2px;
		background: linear-gradient(90deg, var(--accent-color), var(--accent-hover), var(--accent-color));
		transform: scaleX(0);
		transition: transform 0.3s;
	}

	.link-style-10:hover::before {
		transform: scaleX(1);
	}

	.link-style-10:hover {
		color: var(--accent-hover);
		text-shadow: 0 0 8px rgba(58, 134, 255, 0.6);
	}

	@media (max-width: 768px) {
		body {
			padding: 1rem;
		}

		h1 {
			font-size: 2rem;
		}

		.proposal-section {
			padding: 1.5rem;
		}

		.example {
			padding: 1rem;
		}
	}
</style>

---
import DiscountGrid from '../components/grid/DiscountGrid.astro';
import { fetchEnrichedDiscounts } from '../utils/dataFetcher.js';
import { getTexturePath } from '../utils/textures.js';

const { dateRange, items, shopCards, catIcons } = fetchEnrichedDiscounts();
const baseUrl = import.meta.env.BASE_URL;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>War Robots Frontiers Discounts</title>
		<link rel="stylesheet" href={`${baseUrl}global.css`} />
	</head>
	<body>
		<main class="app-container">
			<header>
				<h1>War Robots Frontiers Discounts</h1>
				{dateRange && (
					<h2>
						Salvage <img src={getTexturePath('/WRFrontiers/Content/Sparrow/UI/Textures/Meta/Currency/T_CreditsLarge', baseUrl)} class="currency-icon" alt="Salvage" /> and Intel <img src={getTexturePath('/WRFrontiers/Content/Sparrow/UI/Textures/Meta/Currency/T_IntelLarge', baseUrl)} class="currency-icon" alt="Intel" /> Discounts  -  <strong>{dateRange}</strong>
					</h2>
				)}
			</header>
			
			<DiscountGrid items={items} shopCards={shopCards} catIcons={catIcons} />

			<div class="discount-info" style="text-align: center;">
				<p>Salvage is 50% reduced and Intel is ~62% reduced</p>
			</div>
			
			<footer class="feedback-section">
				<div class="feedback-link">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
						<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
					</svg>
					<span>Got feedback? Message @Surxe on Discord</span>
				</div>
			</footer>
		</main>
	</body>
</html>

<style>
	:root {
		--bg-color: #0f1115;
		--text-color: #e0e0e0;
		--accent-color: #3a86ff;
	}

	body {
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Inter', system-ui, sans-serif;
		margin: 0;
		padding: 0;
	}

	.app-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1rem 2rem;
	}

	header {
		text-align: center;
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	h2 {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 4px;
		font-size: 1.25rem;
		margin-bottom: 0.5rem;
	}

	.currency-icon {
		width: 20px;
		height: 20px;
		object-fit: contain;
		vertical-align: middle;
	}

	.feedback-section {
		text-align: center;
		margin-top: 3rem;
		padding-top: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.feedback-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--text-color);
		text-decoration: none;
		opacity: 0.7;
		transition: opacity 0.2s ease;
		cursor: pointer;
	}

	.feedback-link:hover {
		opacity: 1;
	}

	.feedback-link svg {
		color: #5865F2;
	}

	@media (max-width: 768px) {
		header {
			text-align: center;
		}

		.feedback-section {
			text-align: center;
		}
	}
</style>

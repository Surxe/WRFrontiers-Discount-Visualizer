---
import DiscountPage from '../components/DiscountPage.astro';
import { fetchEnrichedDiscounts } from '../utils/dataFetcher.js';
import { fetchWeeksManifest } from '../utils/weeksManifest.js';

const weeks = fetchWeeksManifest();
// Always load the latest week (first in the list)
const latestWeek = weeks && weeks.length > 0 ? weeks[0] : null;
const data = fetchEnrichedDiscounts(latestWeek ? latestWeek.file : null);

const currentSlug = latestWeek ? latestWeek.slug : null;
---

<DiscountPage 
  {...data} 
  weeks={weeks} 
  currentSlug={currentSlug} 
/>

---
import DiscountPage from '../components/DiscountPage.astro';
import { fetchEnrichedDiscounts } from '../utils/dataFetcher.js';
import { fetchWeeksManifest } from '../utils/weeksManifest.js';
import { getCurrentOrLatestWeek } from '../utils/dateValidator.js';

const weeks = fetchWeeksManifest();
// fetchEnrichedDiscounts with no args will automatically load the current/latest week
const data = fetchEnrichedDiscounts();

const activeWeek = getCurrentOrLatestWeek(weeks);
const currentSlug = activeWeek ? activeWeek.slug : null;
---

<DiscountPage 
  {...data} 
  weeks={weeks} 
  currentSlug={currentSlug} 
/>

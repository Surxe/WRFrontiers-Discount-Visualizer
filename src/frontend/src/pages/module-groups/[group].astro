---
import GenericPage from '../../components/GenericPage.astro';
import { getTexturePath } from '../../utils/textures.js';
import { fetchModulesByCategory, getCategoryIdFromSlug, getModuleCategoryName } from '../../utils/moduleData.js';
import { getModuleDiscountWeeks } from '../../utils/discountHistory.js';

export async function getStaticPaths() {
	const categories = [
		{ slug: 'ability', id: 'DA_ModuleCategory_Ability.0', name: 'Supply Gear' },
		{ slug: 'chassis', id: 'DA_ModuleCategory_Chassis.0', name: 'Chassis' },
		{ slug: 'shoulder', id: 'DA_ModuleCategory_Shoulder.0', name: 'Shoulder' },
		{ slug: 'torso', id: 'DA_ModuleCategory_Torso.0', name: 'Torso' },
		{ slug: 'weapon', id: 'DA_ModuleCategory_Weapon.0', name: 'Weapons' },
	];

	return categories.map(category => ({
		params: { group: category.slug },
		props: { category }
	}));
}

const { category } = Astro.props;
const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';

const categoryId = category.id;
const categoryName = category.name;
const modules = fetchModulesByCategory(categoryId);

// Add discount weeks to each module
const modulesWithDiscounts = modules.map(module => ({
	...module,
	discountWeeks: getModuleDiscountWeeks(module.id),
}));
---

<GenericPage 
	title={`${categoryName} Modules - WRF Discounts`} 
	description={`List of ${categoryName.toLowerCase()} modules with their discount history`} 
	baseUrl={baseUrl}
>
	<h1>{categoryName} Modules</h1>
	
	<table>
		<thead>
			<tr>
				<th>Icon</th>
				<th>Name</th>
				<th>Discount Weeks</th>
			</tr>
		</thead>
		<tbody>
			{modulesWithDiscounts.length > 0 ? (
				modulesWithDiscounts.map(module => (
					<tr>
						<td>
							{module.iconPath && (
								<img 
									src={getTexturePath(module.iconPath, baseUrl)} 
									alt={module.name}
									class="module-icon"
								/>
							)}
						</td>
						<td>{module.name}</td>
						<td>{module.discountWeeks.join(', ') || 'Never'}</td>
					</tr>
				))
			) : (
				<tr>
					<td colspan="3">No modules found in this category</td>
				</tr>
			)}
		</tbody>
	</table>
</GenericPage>

<style>
	table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 2rem;
	}

	th, td {
		padding: 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--sidebar-border);
	}

	th {
		background-color: var(--sidebar-bg);
		font-weight: 600;
	}

	.module-icon {
		width: 32px;
		height: 32px;
		object-fit: contain;
	}

	@media (max-width: 768px) {
		table {
			font-size: 0.875rem;
		}

		.module-icon {
			width: 24px;
			height: 24px;
		}
	}
</style>

---
import GenericPage from '../../components/GenericPage.astro';
import { getTexturePath } from '../../utils/textures.js';
import { fetchModulesByGroup, fetchModuleGroups } from '../../utils/moduleData.js';
import { getModuleDiscountWeeks } from '../../utils/discountHistory.js';

export async function getStaticPaths() {
	const groups = fetchModuleGroups();

	return Object.entries(groups).map(([groupId, group]: [string, any]) => ({
		params: { group: groupId },
		props: { groupId, groupName: group.name.en }
	}));
}

const { groupId, groupName } = Astro.props;
const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';

const modules = fetchModulesByGroup(groupId);

// Add discount weeks to each module
const modulesWithDiscounts = modules.map(module => ({
	...module,
	discountWeeks: getModuleDiscountWeeks(module.id),
}));
---

<GenericPage 
	title={`${groupName} - WRF Discounts`} 
	description={`List of ${groupName.toLowerCase()} modules with their discount history`} 
	baseUrl={baseUrl}
>
	<h1>{groupName}</h1>
	
	<table>
		<thead>
			<tr>
				<th>Icon</th>
				<th>Name</th>
				<th>Discount Weeks</th>
			</tr>
		</thead>
		<tbody>
			{modulesWithDiscounts.length > 0 ? (
				modulesWithDiscounts.map(module => (
					<tr>
						<td>
							{module.iconPath && (
								<img 
									src={getTexturePath(module.iconPath, baseUrl)} 
									alt={module.name}
									class="module-icon"
								/>
							)}
						</td>
						<td>{module.name}</td>
						<td>{module.discountWeeks.join(', ') || 'Never'}</td>
					</tr>
				))
			) : (
				<tr>
					<td colspan="3">No modules found in this group</td>
				</tr>
			)}
		</tbody>
	</table>
</GenericPage>

<style>
	table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 2rem;
	}

	th, td {
		padding: 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--sidebar-border);
	}

	th {
		background-color: var(--sidebar-bg);
		font-weight: 600;
	}

	.module-icon {
		width: 32px;
		height: 32px;
		object-fit: contain;
	}

	@media (max-width: 768px) {
		table {
			font-size: 0.875rem;
		}

		.module-icon {
			width: 24px;
			height: 24px;
		}
	}
</style>

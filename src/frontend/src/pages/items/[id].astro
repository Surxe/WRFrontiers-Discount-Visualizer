---
import GenericPage from '../../components/GenericPage.astro';
import NavBar from '../../components/NavBar.astro';
import { getTexturePath } from '../../utils/textures.js';
import { fetchModulesByGroup, fetchModuleGroups } from '../../utils/moduleData.js';
import { fetchAllVbots, getVbotName, getVbotIconPath, getVbotCharacterType } from '../../utils/vbotData.js';
import { getModuleDiscountWeeks, getVbotDiscountWeeks } from '../../utils/discountHistory.js';

export async function getStaticPaths() {
	const groups = fetchModuleGroups();
	const vbots = fetchAllVbots();
	const allowedGroups = ['light-weapon', 'heavy-weapon', 'titan-weapon', 'supply-gear', 'cycle-gear'];

	const paths: any[] = [];

	// Add module group paths
	for (const [groupId, group] of Object.entries(groups)) {
		if (allowedGroups.includes(groupId)) {
			paths.push({
				params: { id: groupId },
				props: { type: 'module-group', id: groupId, name: (group as any).name.en }
			});
		}
	}

	// Add virtual bot paths
	for (const [vbotId, vbot] of Object.entries(vbots)) {
		paths.push({
			params: { id: vbotId },
			props: { type: 'virtual-bot', id: vbotId, name: getVbotName(vbot) }
		});
	}

	return paths;
}

const { type, id, name } = Astro.props;
const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';

let itemsWithDiscounts: any[] = [];

if (type === 'module-group') {
	const modules = fetchModulesByGroup(id);
	itemsWithDiscounts = modules.map(module => ({
		...module,
		discountWeeks: getModuleDiscountWeeks(module.id),
	}));
} else if (type === 'virtual-bot') {
	const vbot = fetchAllVbots()[id];
	if (vbot) {
		itemsWithDiscounts = [{
			id,
			name: getVbotName(vbot),
			iconPath: getVbotIconPath(vbot),
			characterType: getVbotCharacterType(vbot),
			discountWeeks: getVbotDiscountWeeks(id),
		}];
	}
}
---

<GenericPage
	title={`${name} - WRF Discounts`}
	description={`Discount history for ${name}`}
	baseUrl={baseUrl}
>
	<NavBar baseUrl={baseUrl} currentPage="items" />
	<h1>{name}</h1>
	
	{type === 'module-group' ? (
		<table>
			<thead>
				<tr>
					<th>Icon</th>
					<th>Name</th>
					<th>Discount Weeks</th>
				</tr>
			</thead>
			<tbody>
				{itemsWithDiscounts.length > 0 ? (
					itemsWithDiscounts.map(item => (
						<tr>
							<td>
								{item.iconPath && (
									<img 
										src={getTexturePath(item.iconPath, baseUrl)} 
										alt={item.name}
										class="item-icon"
									/>
								)}
							</td>
							<td>{item.name}</td>
							<td>{item.discountWeeks.join(', ') || 'Never'}</td>
						</tr>
					))
				) : (
					<tr>
						<td colspan="3">No items found</td>
					</tr>
				)}
			</tbody>
		</table>
	) : (
		<table>
			<thead>
				<tr>
					<th>Icon</th>
					<th>Name</th>
					<th>Type</th>
					<th>Discount Weeks</th>
				</tr>
			</thead>
			<tbody>
				{itemsWithDiscounts.length > 0 ? (
					itemsWithDiscounts.map(item => (
						<tr>
							<td>
								{item.iconPath && (
									<img 
										src={getTexturePath(item.iconPath, baseUrl)} 
										alt={item.name}
										class="item-icon"
									/>
								)}
							</td>
							<td>{item.name}</td>
							<td>{item.characterType}</td>
							<td>{item.discountWeeks.join(', ') || 'Never'}</td>
						</tr>
					))
				) : (
					<tr>
						<td colspan="4">No items found</td>
					</tr>
				)}
			</tbody>
		</table>
	)}
</GenericPage>

<style>
	:root {
		--sidebar-bg: #161920;
		--sidebar-border: #232733;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 2rem;
	}

	th, td {
		padding: 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--sidebar-border);
	}

	th {
		background-color: var(--sidebar-bg);
		font-weight: 600;
	}

	.item-icon {
		width: 32px;
		height: 32px;
		object-fit: contain;
	}

	@media (max-width: 768px) {
		table {
			font-size: 0.875rem;
		}

		.item-icon {
			width: 24px;
			height: 24px;
		}
	}
</style>

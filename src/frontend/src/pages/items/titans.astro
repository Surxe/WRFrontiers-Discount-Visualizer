---
import GenericPage from '../../components/GenericPage.astro';
import { getTexturePath } from '../../utils/textures.js';
import { fetchAllVbots, getVbotName, getVbotIconPath, getVbotCharacterType } from '../../utils/vbotData.js';
import { getVbotDiscountWeeks } from '../../utils/discountHistory.js';

const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
const vbots = fetchAllVbots();
const navLinks = [
	{ href: baseUrl, text: 'Home' },
	{ href: `${baseUrl}items`, text: 'Items' },
];

// Filter to only titans
const titanList = Object.entries(vbots)
	.filter(([id, vbot]) => getVbotCharacterType(vbot) === 'Titan')
	.map(([id, vbot]) => ({
		id,
		name: getVbotName(vbot),
		iconPath: getVbotIconPath(vbot),
		characterType: getVbotCharacterType(vbot),
		discountWeeks: getVbotDiscountWeeks(id),
	}))
	.sort((a, b) => a.name.localeCompare(b.name));
---

<GenericPage
	title="Titans - WRF Discounts"
	description="List of all titan virtual bots with their discount history"
	baseUrl={baseUrl}
	navLinks={navLinks}
>
	<h1>Titans</h1>

	<table>
		<thead>
			<tr>
				<th>Icon</th>
				<th>Name</th>
				<th>Discount Weeks</th>
			</tr>
		</thead>
		<tbody>
			{titanList.map(vbot => (
				<tr>
					<td>
						{vbot.iconPath && (
							<img
								src={getTexturePath(vbot.iconPath, baseUrl)}
								alt={vbot.name}
								class="vbot-icon"
							/>
						)}
					</td>
					<td>
						<a href={`${baseUrl}items/${vbot.id}`}>{vbot.name}</a>
					</td>
					<td>{vbot.discountWeeks.join(', ') || 'Never'}</td>
				</tr>
			))}
		</tbody>
	</table>
</GenericPage>

<style>
	:root {
		--sidebar-bg: #161920;
		--sidebar-border: #232733;
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
	}

	table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 2rem;
	}

	th, td {
		padding: 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--sidebar-border);
	}

	th {
		background-color: var(--sidebar-bg);
		font-weight: 600;
	}

	.vbot-icon {
		width: 32px;
		height: 32px;
		object-fit: contain;
	}

	a {
		color: var(--accent-color);
		text-decoration: none;
	}

	a:hover {
		color: var(--accent-hover);
		text-decoration: underline;
	}

	@media (max-width: 768px) {
		table {
			font-size: 0.875rem;
		}

		.vbot-icon {
			width: 24px;
			height: 24px;
		}
	}
</style>

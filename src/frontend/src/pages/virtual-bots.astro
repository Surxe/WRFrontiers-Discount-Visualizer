---
import GenericPage from '../components/GenericPage.astro';
import { getTexturePath } from '../utils/textures.js';
import { fetchAllVbots, getVbotName, getVbotIconPath, getVbotCharacterType } from '../utils/vbotData.js';
import { getVbotDiscountWeeks } from '../utils/discountHistory.js';

const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
const vbots = fetchAllVbots();

// Convert to array and add discount weeks
const vbotList = Object.entries(vbots).map(([id, vbot]) => ({
	id,
	name: getVbotName(vbot),
	iconPath: getVbotIconPath(vbot),
	characterType: getVbotCharacterType(vbot),
	discountWeeks: getVbotDiscountWeeks(id),
})).sort((a, b) => a.name.localeCompare(b.name));
---

<GenericPage 
	title="All Virtual Bots - WRF Discounts" 
	description="List of all virtual bots with their discount history" 
	baseUrl={baseUrl}
>
	<h1>All Virtual Bots</h1>
	
	<table>
		<thead>
			<tr>
				<th>Icon</th>
				<th>Name</th>
				<th>Type</th>
				<th>Discount Weeks</th>
			</tr>
		</thead>
		<tbody>
			{vbotList.map(vbot => (
				<tr>
					<td>
						{vbot.iconPath && (
							<img 
								src={getTexturePath(vbot.iconPath, baseUrl)} 
								alt={vbot.name}
								class="vbot-icon"
							/>
						)}
					</td>
					<td>{vbot.name}</td>
					<td>{vbot.characterType}</td>
					<td>{vbot.discountWeeks.join(', ') || 'Never'}</td>
				</tr>
			))}
		</tbody>
	</table>
</GenericPage>

<style>
	table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 2rem;
	}

	th, td {
		padding: 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--sidebar-border);
	}

	th {
		background-color: var(--sidebar-bg);
		font-weight: 600;
	}

	.vbot-icon {
		width: 32px;
		height: 32px;
		object-fit: contain;
	}

	@media (max-width: 768px) {
		table {
			font-size: 0.875rem;
		}

		.vbot-icon {
			width: 24px;
			height: 24px;
		}
	}
</style>

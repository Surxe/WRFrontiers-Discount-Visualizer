---
import GenericPage from '../components/GenericPage.astro';
import NavBar from '../components/NavBar.astro';

const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
---

<GenericPage
	title="Terms of Service - WRF Discounts"
	description="Terms of Service for the WRFrontiers Discount Visualizer"
	baseUrl={baseUrl}
>
	<NavBar baseUrl={baseUrl} currentPage="terms" />
	<h1>Terms of Service</h1>
	<div class="legal-content">
		<p class="last-updated">Last Updated: June 19, 2026</p>

		<section>
			<h2>1. Acceptance of Terms</h2>
			<p>
				By accessing or using the WRFrontiers Discount Visualizer (the "Service"), you agree to be bound by these Terms of Service. 
				If you do not agree to these terms, please do not use the Service.
			</p>
		</section>

		<section>
			<h2>2. Nature of the Service</h2>
			<p>
				The WRFrontiers Discount Visualizer is an unofficial fan-made tool designed to help players track and visualize 
				discount information for the War Robots Frontiers game. This Service is provided for informational purposes only 
				and is not affiliated with, endorsed by, or sponsored by Pixonic, My Games, or the official War Robots Frontiers game.
			</p>
		</section>

		<section>
			<h2>3. Intellectual Property</h2>
			<p>
				All game assets, trademarks, and copyrighted materials displayed on this Service belong to their respective owners, 
				including but not limited to Pixonic and My Games. The use of such materials is believed to fall under fair use 
				for informational and educational purposes. No ownership of any game assets is claimed by this Service.
			</p>
		</section>

		<section>
			<h2>4. Accuracy of Information</h2>
			<p>
				Discount information displayed on this Service is retrieved from official news posts and is provided to the best 
				of our ability. However, we make no guarantees about the completeness, accuracy, reliability, or timeliness of 
				this information. Always verify discount information through official game channels.
			</p>
		</section>

		<section>
			<h2>5. Disclaimer of Warranties</h2>
			<p>
				The Service is provided "as is" without any warranty, express or implied. We disclaim all warranties, including 
				but not limited to warranties of merchantability, fitness for a particular purpose, and non-infringement of 
				third-party rights.
			</p>
		</section>

		<section>
			<h2>6. Limitation of Liability</h2>
			<p>
				In no event shall we be liable for any indirect, incidental, special, consequential, or punitive damages, 
				including without limitation, loss of profits, data, use, goodwill, or other intangible losses, resulting from 
				your access to or use of or inability to access or use the Service.
			</p>
		</section>

		<section>
			<h2>7. User Conduct</h2>
			<p>
				You agree not to use the Service for any unlawful purpose or in any way that could damage the Service or 
				interfere with any other party's use and enjoyment of the Service. You agree not to attempt to gain unauthorized 
				access to the Service or any related systems or networks.
			</p>
		</section>

		<section>
			<h2>8. Modifications to Terms</h2>
			<p>
				We reserve the right to modify these Terms of Service at any time. Changes will be effective immediately upon 
				posting to the Service. Your continued use of the Service after such modifications constitutes your acceptance 
				of the updated terms.
			</p>
		</section>

		<section>
			<h2>9. Contact Information</h2>
			<p>
				If you have any questions about these Terms of Service, please contact us through the appropriate channels 
				provided in the project repository or reach out on Discord at <strong>@Surxe</strong>.
			</p>
		</section>
	</div>
</GenericPage>

<style>
	.legal-content {
		max-width: 900px;
		margin: 0 auto;
		line-height: 1.8;
	}

	.last-updated {
		text-align: center;
		color: var(--text-muted);
		font-style: italic;
		margin-bottom: 2rem;
	}

	section {
		margin-bottom: 2.5rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--sidebar-border);
	}

	section:last-of-type {
		border-bottom: none;
	}

	h2 {
		color: var(--accent-color);
		margin-bottom: 1rem;
	}

	p {
		margin-bottom: 1rem;
		color: var(--text-color);
	}

	@media (max-width: 768px) {
		.legal-content {
			padding: 0 0.5rem;
		}
	}
</style>

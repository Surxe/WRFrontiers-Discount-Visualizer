---
import GenericPage from '../components/GenericPage.astro';
import { fetchModuleGroups, fetchCatIcons } from '../utils/moduleData.js';
import { getTexturePath } from '../utils/textures.js';

const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
const groups = fetchModuleGroups();
const catIcons = fetchCatIcons();

// Icon mapping based on GridHeader indices
// 1: Torso, 2: Shoulder, 3: Chassis, 4: Light Wep, 5: Heavy Wep, 6: Supply Gear, 7: Cycle Gear
const getIconForGroup = (groupId: string) => {
	const iconMap: Record<string, number> = {
		'titan-torsos': 1,
		'titan-shoulder': 2,
		'titan-chassis': 3,
		'titan-weapon': 5,
		'non-titan-torsos': 1,
		'non-titan-shoulder': 2,
		'non-titan-chassis': 3,
		'light-weapon': 4,
		'heavy-weapon': 5,
		'supply-gear': 6,
		'cycle-gear': 7,
	};
	return catIcons[iconMap[groupId]] || null;
};

// Convert to array and sort by sort_order
const sortedGroups = Object.entries(groups)
	.map(([id, group]: [string, any]) => ({
		id,
		name: group.name?.en || id,
		sortOrder: group.sort_order || 0,
		isTitan: group.titan || false,
		isVirtualBotModule: group.virtual_bot_module || false,
		iconPath: getIconForGroup(id),
	}))
	.sort((a, b) => a.sortOrder - b.sortOrder);

// Filter to only specific groups
const allowedGroups = ['light-weapon', 'heavy-weapon', 'titan-weapon', 'supply-gear', 'cycle-gear'];
const filteredGroups = sortedGroups.filter(g => allowedGroups.includes(g.id));
---

<GenericPage 
	title="Module Groups - WRF Discounts" 
	description="List of all module groups" 
	baseUrl={baseUrl}
	navLinks={[{ href: baseUrl, text: 'Home' }]}
>
	<h1>Module Groups</h1>

	<ul class="group-list">
		{filteredGroups.map(group => (
			<li>
				<a href={`${baseUrl}module-groups/${group.id}`}>
					{group.iconPath && (
						<img src={getTexturePath(group.iconPath, baseUrl)} alt="" class="group-icon" />
					)}
					<span>{group.name}</span>
				</a>
			</li>
		))}
	</ul>
</GenericPage>

<style>
	:root {
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
	}

	.group-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 0.75rem;
	}

	.group-list li {
		margin: 0;
	}

	.group-list a {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem;
		background-color: var(--sidebar-bg);
		border-radius: 0.5rem;
		color: var(--text-color);
		text-decoration: none;
		transition: background-color 0.2s, color 0.2s;
	}

	.group-list a:hover {
		background-color: var(--active-bg);
		color: var(--accent-color);
	}

	.group-icon {
		width: 32px;
		height: 32px;
		object-fit: contain;
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.group-list {
			grid-template-columns: 1fr;
		}
	}
</style>

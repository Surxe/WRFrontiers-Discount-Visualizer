---
import GenericPage from '../components/GenericPage.astro';
import { fetchModuleGroups, fetchCatIcons } from '../utils/moduleData.js';
import { getTexturePath } from '../utils/textures.js';

const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
const groups = fetchModuleGroups();
const catIcons = fetchCatIcons();
const navLinks = [{ href: baseUrl, text: 'Home' }];

// Icon mapping based on GridHeader indices
// 1: Torso, 2: Shoulder, 3: Chassis, 4: Light Wep, 5: Heavy Wep, 6: Supply Gear, 7: Cycle Gear
const getIconForGroup = (groupId: string) => {
	const iconMap: Record<string, number> = {
		'light-weapon': 4,
		'heavy-weapon': 5,
		'titan-weapon': 5,
		'supply-gear': 6,
		'cycle-gear': 7,
	};
	return catIcons[iconMap[groupId]] || null;
};

// Filter to only specific groups
const allowedGroups = ['light-weapon', 'heavy-weapon', 'titan-weapon', 'supply-gear', 'cycle-gear'];
const filteredGroups = Object.entries(groups)
	.filter(([id]) => allowedGroups.includes(id))
	.map(([id, group]: [string, any]) => ({
		id,
		name: group.name?.en || id,
		sortOrder: group.sort_order || 0,
		iconPath: getIconForGroup(id),
	}))
	.sort((a, b) => a.sortOrder - b.sortOrder);

// Add mechs and titans as special items
const specialItems = [
	{ id: 'mechs', name: 'Mechs', iconPath: catIcons[1] || null }, // Use torso icon for mechs
	{ id: 'titans', name: 'Titans', iconPath: catIcons[1] || null }, // Use torso icon for titans
];

// Combine all items
const allItems = [...filteredGroups, ...specialItems];
---

<GenericPage
	title="Items - WRF Discounts"
	description="List of all items with their discount history"
	baseUrl={baseUrl}
	navLinks={navLinks}
>
	<h1>Items</h1>

	<ul class="group-list">
		{allItems.map(item => (
			<li>
				<a href={`${baseUrl}items/${item.id}`}>
					{item.iconPath && (
						<img src={getTexturePath(item.iconPath, baseUrl)} alt="" class="group-icon" />
					)}
					<span>{item.name}</span>
				</a>
			</li>
		))}
	</ul>
</GenericPage>

<style>
	:root {
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
	}

	.group-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: 0.75rem;
	}

	.group-list li {
		margin: 0;
	}

	.group-list a {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.75rem;
		background-color: var(--sidebar-bg);
		border-radius: 0.5rem;
		color: var(--text-color);
		text-decoration: none;
		transition: background-color 0.2s, color 0.2s;
	}

	.group-list a:hover {
		background-color: var(--active-bg);
		color: var(--accent-color);
	}

	.group-icon {
		width: 32px;
		height: 32px;
		object-fit: contain;
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.group-list {
			grid-template-columns: 1fr;
		}
	}
</style>

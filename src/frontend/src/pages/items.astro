---
import GenericPage from '../components/GenericPage.astro';
import NavBar from '../components/NavBar.astro';
import { fetchModuleGroups, fetchCatIcons, fetchModulesByGroup } from '../utils/moduleData.js';
import { getTexturePath } from '../utils/textures.js';
import { fetchAllVbots, getVbotName, getVbotIconPath, getVbotCharacterType } from '../utils/vbotData.js';
import { getVbotDiscountWeeks, getModuleDiscountWeeks, getModuleVirtualBots, fetchDiscountHistory } from '../utils/discountHistory.js';

const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
const groups = fetchModuleGroups();
const catIcons = fetchCatIcons();
const vbots = fetchAllVbots();

// Get total weeks and virtual bots for percentage calculations
const discountHistory = fetchDiscountHistory();

// Get all unique weeks from the discount history
const allWeeks = new Set<string>();
Object.values(discountHistory.modules).forEach((m: any) => {
	const weeks = Array.isArray(m) ? m : (m.weeks || []);
	weeks.forEach((week: string) => allWeeks.add(week));
});
Object.values(discountHistory.virtualBots).forEach((v: any) => {
	const weeks = Array.isArray(v) ? v : (v.weeks || []);
	weeks.forEach((week: string) => allWeeks.add(week));
});

const totalWeeks = allWeeks.size;
const totalVbots = Object.keys(vbots).length;

// Get expanded category from query param
const url = new URL(Astro.request.url);
const expandedCategory = url.searchParams.get('group');

// Icon mapping based on GridHeader indices
// 1: Torso, 2: Shoulder, 3: Chassis, 4: Light Wep, 5: Heavy Wep, 6: Supply Gear, 7: Cycle Gear
const getIconForGroup = (groupId: string) => {
	const iconMap: Record<string, number> = {
		'light-weapon': 4,
		'heavy-weapon': 5,
		'titan-weapon': 5,
		'supply-gear': 6,
		'cycle-gear': 7,
	};
	return catIcons[iconMap[groupId]] || null;
};

// Filter to only specific groups
const allowedGroups = ['light-weapon', 'heavy-weapon', 'titan-weapon', 'supply-gear', 'cycle-gear'];
const filteredGroups = Object.entries(groups)
	.filter(([id]) => allowedGroups.includes(id))
	.map(([id, group]: [string, any]) => ({
		id,
		name: group.name?.en || id,
		sortOrder: group.sort_order || 0,
		iconPath: getIconForGroup(id),
		showVirtualBots: id !== 'titan-weapon', // Don't show virtual bots for titan weapons
		modules: fetchModulesByGroup(id).map(module => {
			const discountWeeks = getModuleDiscountWeeks(module.id);
			const virtualBots = getModuleVirtualBots(module.id);
			const discountPercentage = totalWeeks > 0 ? ((discountWeeks.length / totalWeeks) * 100).toFixed(1) : '0';
			const vbotPortion = totalVbots > 0 ? ((virtualBots.length / totalVbots) * 100).toFixed(1) : '0';
			
			return {
				...module,
				discountWeeks,
				virtualBots,
				discountPercentage,
				vbotPortion,
			};
		}),
	}))
	.sort((a, b) => a.sortOrder - b.sortOrder);

// Filter to only mechs
const mechList = Object.entries(vbots)
	.filter(([id, vbot]) => getVbotCharacterType(vbot) === 'Mech')
	.map(([id, vbot]) => {
		const discountWeeks = getVbotDiscountWeeks(id);
		const discountPercentage = totalWeeks > 0 ? ((discountWeeks.length / totalWeeks) * 100).toFixed(1) : '0';
		return {
			id,
			name: getVbotName(vbot),
			iconPath: getVbotIconPath(vbot),
			discountWeeks,
			discountPercentage,
		};
	})
	.sort((a, b) => a.name.localeCompare(b.name));

// Filter to only titans
const titanList = Object.entries(vbots)
	.filter(([id, vbot]) => getVbotCharacterType(vbot) === 'Titan')
	.map(([id, vbot]) => {
		const discountWeeks = getVbotDiscountWeeks(id);
		const discountPercentage = totalWeeks > 0 ? ((discountWeeks.length / totalWeeks) * 100).toFixed(1) : '0';
		return {
			id,
			name: getVbotName(vbot),
			iconPath: getVbotIconPath(vbot),
			discountWeeks,
			discountPercentage,
		};
	})
	.sort((a, b) => a.name.localeCompare(b.name));
---

<GenericPage
	title="Items - WRF Discounts"
	description="List of all items with their discount history"
	baseUrl={baseUrl}
>
	<NavBar baseUrl={baseUrl} currentPage="items" />
	<h1>Items</h1>

	<!-- Module Groups -->
	{filteredGroups.map(group => (
		<div class="category" data-category={group.id}>
			<button class="category-header" aria-expanded={expandedCategory === group.id}>
				<span class="category-title">
					{group.iconPath && (
						<img src={getTexturePath(group.iconPath, baseUrl)} alt="" class="category-icon-img" />
					)}
					{group.name}
				</span>
				<span class="category-icon">▼</span>
			</button>
			<div class="category-content" class:list={{ expanded: expandedCategory === group.id }}>
				<table class="category-table">
					<thead>
						<tr>
							<th>Name</th>
							<th>Discount Weeks</th>
							<th>
								<span class="header-with-tooltip">
									Appearance Rate
									<span class="tooltip-icon" title="Portion of weeks this item was discounted on">?</span>
								</span>
							</th>
							{group.showVirtualBots && (
								<th>
									<span class="header-with-tooltip">
										Bot Usage
										<span class="tooltip-icon" title="Portion of virtual bots this item is featured in">?</span>
									</span>
								</th>
							)}
						</tr>
					</thead>
					<tbody>
						{group.modules.length > 0 ? (
							group.modules.map(module => (
								<tr>
									<td>
										<span class="name-with-icon">
											{module.iconPath && (
												<img
													src={getTexturePath(module.iconPath, baseUrl)}
													alt={module.name}
													class="module-icon"
												/>
											)}
											{module.name}
										</span>
									</td>
									<td>
										{module.discountWeeks.length > 0 ? (
											module.discountWeeks.map((week, i) => (
												<>
													{i > 0 && ', '}
													<a href={`${baseUrl}week/${week}`} class="week-link">{week}</a>
												</>
											))
										) : 'Never'}
									</td>
									<td class="percentage-cell">{module.discountPercentage}%</td>
									{group.showVirtualBots && (
										<td class="percentage-cell">{module.vbotPortion}% ({module.virtualBots.length})</td>
									)}
								</tr>
							))
						) : (
							<tr>
								<td colspan={group.showVirtualBots ? 4 : 3}>No modules found in this group</td>
							</tr>
						)}
					</tbody>
				</table>
			</div>
		</div>
	))}

	<!-- Mechs Category -->
	<div class="category" data-category="mechs">
		<button class="category-header" aria-expanded={expandedCategory === 'mechs'}>
			<span class="category-title">Mechs</span>
			<span class="category-icon">▼</span>
		</button>
		<div class="category-content" class:list={{ expanded: expandedCategory === 'mechs' }}>
			<table class="category-table">
				<thead>
					<tr>
						<th>Name</th>
						<th>Discount Weeks</th>
						<th>
							<span class="header-with-tooltip">
								Appearance Rate
								<span class="tooltip-icon" title="Portion of weeks this item was discounted on">?</span>
							</span>
						</th>
					</tr>
				</thead>
				<tbody>
					{mechList.map(vbot => (
						<tr>
							<td>
								<span class="name-with-icon">
									{vbot.iconPath && (
										<img
											src={getTexturePath(vbot.iconPath, baseUrl)}
											alt={vbot.name}
											class="vbot-icon"
										/>
									)}
									{vbot.name}
								</span>
							</td>
							<td>
								{vbot.discountWeeks.length > 0 ? (
									vbot.discountWeeks.map((week, i) => (
										<>
											{i > 0 && ', '}
											<a href={`${baseUrl}week/${week}`} class="week-link">{week}</a>
										</>
									))
								) : 'Never'}
							</td>
							<td class="percentage-cell">{vbot.discountPercentage}%</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</div>

	<!-- Titans Category -->
	<div class="category" data-category="titans">
		<button class="category-header" aria-expanded={expandedCategory === 'titans'}>
			<span class="category-title">Titans</span>
			<span class="category-icon">▼</span>
		</button>
		<div class="category-content" class:list={{ expanded: expandedCategory === 'titans' }}>
			<table class="category-table">
				<thead>
					<tr>
						<th>Name</th>
						<th>Discount Weeks</th>
						<th>
							<span class="header-with-tooltip">
								Appearance Rate
								<span class="tooltip-icon" title="Portion of weeks this item was discounted on">?</span>
							</span>
						</th>
					</tr>
				</thead>
				<tbody>
					{titanList.map(vbot => (
						<tr>
							<td>
								<span class="name-with-icon">
									{vbot.iconPath && (
										<img
											src={getTexturePath(vbot.iconPath, baseUrl)}
											alt={vbot.name}
											class="vbot-icon"
										/>
									)}
									{vbot.name}
								</span>
							</td>
							<td>
								{vbot.discountWeeks.length > 0 ? (
									vbot.discountWeeks.map((week, i) => (
										<>
											{i > 0 && ', '}
											<a href={`${baseUrl}week/${week}`} class="week-link">{week}</a>
										</>
									))
								) : 'Never'}
							</td>
							<td class="percentage-cell">{vbot.discountPercentage}%</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</div>

	<script>
		// Handle category toggle
		document.querySelectorAll('.category-header').forEach(button => {
			button.addEventListener('click', () => {
				const category = button.parentElement;
				if (!category) return;
				const content = category.querySelector('.category-content');
				if (!content) return;
				const isExpanded = content.classList.toggle('expanded');
				button.setAttribute('aria-expanded', isExpanded.toString());

				// Update URL query param
				const url = new URL(window.location.href);
				const categoryId = category.dataset.category;
				if (isExpanded && categoryId) {
					url.searchParams.set('group', categoryId);
				} else {
					url.searchParams.delete('group');
				}
				window.history.replaceState({}, '', url);
			});
		});
	</script>
</GenericPage>

<style>
	:root {
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
		--sidebar-bg: #161920;
		--sidebar-border: #232733;
		--text-color: #e0e0e0;
		--active-bg: rgba(58, 134, 255, 0.1);
	}

	.category {
		margin-bottom: 1rem;
		border: 1px solid var(--sidebar-border);
		border-radius: 0.5rem;
		background-color: var(--sidebar-bg);
	}

	.category-header {
		width: 100%;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1rem;
		background: none;
		border: none;
		color: var(--text-color);
		font-size: 1.25rem;
		font-weight: 600;
		cursor: pointer;
		transition: background-color 0.2s;
		position: relative;
	}

	.category-header:hover {
		background-color: var(--active-bg);
	}

	.category-icon {
		position: absolute;
		right: 1rem;
		transition: transform 0.2s;
	}

	.category-header[aria-expanded='true'] .category-icon {
		transform: rotate(180deg);
	}

	.category-icon-img {
		width: 36px;
		height: 36px;
		object-fit: contain;
	}

	.category-title {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		justify-content: center;
		flex: 1;
		padding-right: 2rem;
	}

	.module-icon {
		width: 48px;
		height: 48px;
		object-fit: contain;
	}

	.category-content {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease-out;
	}

	.category-content.expanded {
		max-height: 2000px;
		transition: max-height 0.5s ease-in;
	}

	.category-content > * {
		padding: 0 1rem 1rem;
	}

	.category-table {
		width: 100%;
		border-collapse: collapse;
	}

	.category-table th,
	.category-table td {
		padding: 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--sidebar-border);
	}

	.category-table th {
		background-color: var(--sidebar-bg);
		font-weight: 600;
	}

	.percentage-cell {
		text-align: center;
		font-family: 'Courier New', monospace;
		font-weight: 500;
	}

	.header-with-tooltip {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	.tooltip-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 16px;
		height: 16px;
		border-radius: 50%;
		background-color: var(--accent-color, #3a86ff);
		color: white;
		font-size: 11px;
		font-weight: 700;
		cursor: help;
		transition: background-color 0.2s;
	}

	.tooltip-icon:hover {
		background-color: var(--accent-hover, #2b65cc);
	}

	.week-link {
		color: var(--accent-color, #3a86ff);
		text-decoration: none;
		transition: color 0.2s;
	}

	.week-link:hover {
		color: var(--accent-hover, #2b65cc);
		text-decoration: underline;
	}

	.vbot-icon {
		width: 48px;
		height: 48px;
		object-fit: contain;
	}

	.name-with-icon {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.name-with-icon .module-icon,
	.name-with-icon .vbot-icon {
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		.category-table {
			font-size: 0.875rem;
		}

		.vbot-icon,
		.module-icon {
			width: 36px;
			height: 36px;
		}

		.percentage-cell {
			font-size: 0.8rem;
		}
	}
</style>

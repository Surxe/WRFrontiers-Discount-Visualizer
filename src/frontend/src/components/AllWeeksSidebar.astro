---
import '../styles/all-weeks-sidebar.css';
import { getCurrentOrLatestWeek } from '../utils/dateValidator.js';

const { weeks, currentSlug, baseUrl, nextWeek, nextWeekHref } = Astro.props;
const mainPageWeek = weeks && weeks.length > 0 ? weeks[0] : null;
---

<div class="layout-container" id="layout-container">
  <button
    id="sidebar-toggle"
    class="sidebar-toggle"
    type="button"
    aria-label="Toggle sidebar"
    aria-expanded="true"
  >
    <span class="toggle-label">All Weeks</span>
    <svg class="icon-open" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
    <svg class="icon-close" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>

  <aside class="sidebar" id="sidebar">
    <div class="custom-scrollbar-track" id="custom-scrollbar-track">
      <div class="custom-scrollbar-thumb" id="custom-scrollbar-thumb"></div>
    </div>
    <div class="sidebar-content" id="sidebar-content">
      <ul class="week-list">
        {(() => {
          const groupedWeeks = {};
          (weeks || []).forEach(week => {
            const match = week.date_range.match(/\b(\d{4})\b/);
            const year = match ? match[1] : new Date().getFullYear().toString();
            if (!groupedWeeks[year]) groupedWeeks[year] = [];
            
            const displayLabel = week.date_range.replace(/,?\s*\b\d{4}\b/g, '').trim();
            groupedWeeks[year].push({ ...week, displayLabel });
          });
          
          const sortedYears = Object.keys(groupedWeeks).sort((a, b) => b - a);
          
          return sortedYears.map(year => (
            <li class="year-group">
              <div class="year-label">{year}</div>
              <ul class="year-weeks">
                {groupedWeeks[year].map(week => {
                  let isActive = false;
                  if (currentSlug) {
                    isActive = week.slug === currentSlug;
                  } else {
                    isActive = mainPageWeek ? week.slug === mainPageWeek.slug : false;
                  }
                  const isMainPageWeek = mainPageWeek && week.slug === mainPageWeek.slug;
                  const href = isMainPageWeek ? baseUrl : `${baseUrl}week/${week.slug}`;

                  return (
                    <li>
                      <a href={href} class={`week-link ${isActive ? 'active' : ''}`}>
                        <span class="week-link__label">{week.displayLabel}</span>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </li>
          ));
        })()}
      </ul>
    </div>
  </aside>

  <main class="all-weeks-sidebar__main">
    <slot />
  </main>
</div>

<script>
  import { initAllWeeksSidebar } from '../scripts/all-weeks-sidebar.js';

  initAllWeeksSidebar();
</script>

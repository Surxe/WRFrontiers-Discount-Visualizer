---
const { href = '/robots.txt' } = Astro.props;
const title = "Please use the data from GitHub instead of scraping the website, this ensures real users can always view the site";
---

<a href={href} class="robots-link" target="_blank" rel="noopener noreferrer" title={title}>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" opacity=".15"/>
    <path d="M14 2v6h6"/>
    <path d="M6 20h12V8h-6V2H6v18z"/>
  </svg>
  <span>Robots.txt</span>
</a>

<style>
  .robots-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-color);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s ease;
    cursor: pointer;
  }

  .robots-link:hover {
    opacity: 1;
  }

  .robots-link svg {
    color: #fff;
  }
</style>

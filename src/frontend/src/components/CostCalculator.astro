---
const baseUrl = import.meta.env.BASE_URL || '/';
---
<aside id="cost-calculator-drawer" class="calculator-drawer">
  <div class="calculator-header">
    <h3>Cost Calculator</h3>
    <div class="header-actions">
      <select id="calc-week-select" class="header-select" aria-label="Target Week">
        <option value="none">Target Week...</option>
        <option value="w1">Week 1 (Placeholder)</option>
        <option value="w2">Week 2 (Placeholder)</option>
      </select>
      <button id="clear-calculator" class="clear-btn" aria-label="Clear Calculator">Clear</button>
      <button id="close-calculator" class="close-btn" aria-label="Close Calculator">&times;</button>
    </div>
  </div>
  <div class="calculator-content">
    <div id="calculator-empty-state" class="empty-state">
      Click the + on any module to start calculating
    </div>
    <table id="calculator-table" class="calculator-table" style="display: none;">
      <thead>
        <tr>
          <th>Module</th>
          <th>Qty</th>
          <th>From</th>
          <th>To</th>
          <th>Salvage</th>
          <th>Intel</th>
          <th>Discounted?</th>
        </tr>
      </thead>
      <tbody id="calculator-tbody">
      </tbody>
      <tfoot>
        <tr>
          <td colspan="4" class="total-label">Total:</td>
          <td id="calc-total-salvage">-</td>
          <td id="calc-total-intel">-</td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>
</aside>

<style>
  .calculator-drawer {
    position: fixed;
    top: 0;
    right: -450px;
    width: 450px;
    max-width: 100vw;
    height: 100vh;
    background-color: var(--sidebar-bg, #161920);
    border-left: 1px solid var(--sidebar-border, #232733);
    z-index: 9999;
    transition: right 0.3s ease;
    display: flex;
    flex-direction: column;
    box-shadow: -5px 0 15px rgba(0,0,0,0.5);
  }

  .calculator-drawer.is-open {
    right: 0;
  }

  .calculator-header {
    padding: 1rem;
    border-bottom: 1px solid var(--sidebar-border, #232733);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .calculator-header h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #fff;
  }

  .clear-btn {
    background: transparent;
    border: 1px solid #444;
    color: #aaa;
    border-radius: 4px;
    padding: 2px 8px;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .clear-btn:hover {
    background: #444;
    color: #fff;
  }

  .header-select {
    background: #232733;
    border: 1px solid #444;
    color: #e0e0e0;
    border-radius: 4px;
    padding: 2px 6px;
    font-size: 0.8rem;
    cursor: pointer;
    outline: none;
  }

  .header-select:focus {
    border-color: #666;
  }

  .close-btn {
    background: none;
    border: none;
    color: var(--text-muted, #8b92a5);
    font-size: 1.5rem;
    cursor: pointer;
    line-height: 1;
    padding: 0 0.5rem;
  }

  .close-btn:hover {
    color: #fff;
  }

  .calculator-content {
    padding: 1rem;
    overflow-y: auto;
    flex: 1;
  }

  .empty-state {
    text-align: center;
    color: var(--text-muted, #8b92a5);
    margin-top: 2rem;
    font-style: italic;
  }

  .calculator-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }

  .calculator-table th,
  .calculator-table td {
    padding: 0.5rem;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .calculator-table th {
    color: var(--text-muted, #8b92a5);
    font-weight: normal;
  }

  .calculator-table td.module-col {
    text-align: left;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .calc-icon-wrapper {
    width: 38px;
    height: 59px;
    flex-shrink: 0;
  }
  
  .qty-col {
    white-space: nowrap;
  }

  .qty-btn {
    background: #333;
    border: none;
    color: #fff;
    cursor: pointer;
    width: 20px;
    height: 20px;
    border-radius: 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    margin: 0 2px;
  }

  .qty-btn:hover {
    background: #555;
  }

  .total-label {
    text-align: right;
    font-weight: bold;
  }
</style>

<script>
  import { calculatorStore } from '../scripts/cost-calculator-store.js';

  const drawer = document.getElementById('cost-calculator-drawer');
  const closeBtn = document.getElementById('close-calculator');
  const clearBtn = document.getElementById('clear-calculator');
  const emptyState = document.getElementById('calculator-empty-state');
  const table = document.getElementById('calculator-table');
  const tbody = document.getElementById('calculator-tbody');

  closeBtn.addEventListener('click', () => {
    calculatorStore.toggleDrawer(false);
  });

  clearBtn.addEventListener('click', () => {
    calculatorStore.clearList();
  });

  calculatorStore.addEventListener('change', (e) => {
    const { shoppingList, isOpen } = e.detail;

    // Toggle drawer visibility
    if (isOpen) {
      drawer.classList.add('is-open');
    } else {
      drawer.classList.remove('is-open');
    }

    // Update list UI
    if (shoppingList.length === 0) {
      emptyState.style.display = 'block';
      table.style.display = 'none';
      tbody.innerHTML = '';
    } else {
      emptyState.style.display = 'none';
      table.style.display = 'table';
      
      tbody.innerHTML = shoppingList.map(item => `
        <tr>
          <td class="module-col">
            ${item.iconSrc ? `
              <div class="calc-icon-wrapper" style="
                --grid-scale-unit: 0.5px;
                --module-icon-max-height: 44px;
                --module-card-padding: 3px;
                --module-card-padding-x: 4px;
                --module-card-radius: 4px;
              ">
                <div class="object-box">
                  <div class="module-card object-box__card object-box__card--no-name" style="${item.bgSrc ? `background-image: url('${item.bgSrc}');` : ''}">
                    <div class="module-card__icon">
                      <img class="module-icon" src="${item.iconSrc}" alt="" />
                    </div>
                  </div>
                </div>
              </div>
            ` : ''}
            <span>${item.name}</span>
          </td>
          <td class="qty-col">
            <button class="qty-btn" data-action="minus" data-id="${item.instanceId}">-</button>
            ${item.quantity}
            <button class="qty-btn" data-action="plus" data-id="${item.instanceId}">+</button>
          </td>
          <td>${item.fromLvl}</td>
          <td>${item.toLvl}</td>
          <td>-</td>
          <td>-</td>
          <td>-</td>
        </tr>
      `).join('');
    }
  });

  // Event delegation for quantity buttons
  tbody.addEventListener('click', (e) => {
    const btn = e.target.closest('.qty-btn');
    if (!btn) return;
    
    const action = btn.getAttribute('data-action');
    const id = btn.getAttribute('data-id');
    
    if (action === 'plus') {
      calculatorStore.updateQuantity(id, 1);
    } else if (action === 'minus') {
      calculatorStore.updateQuantity(id, -1);
    }
  });

  // Initial render
  setTimeout(() => {
    calculatorStore.emitChange();
  }, 0);
</script>

---
import DiscountGrid from './grid/DiscountGrid.astro';
import DiscordFeedback from './DiscordFeedback.astro';
import LegalDisclaimer from './LegalDisclaimer.astro';
import AllWeeksSidebar from './AllWeeksSidebar.astro';
import GitHubHistory from './GitHubHistory.astro';
import { getTexturePath } from '../utils/textures.js';
import { categorize } from '../utils/gridData.js';
import { fetchEnrichedDiscounts } from '../utils/dataFetcher.js';
import { getCurrentOrLatestWeek, getNextWeek } from '../utils/dateValidator.js';

const { dateRange, items, shopCards, catIcons, weeks, currentSlug } = Astro.props;
const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
const weekEntries = /** @type {{date_range: string; file: string; slug: string;}[]} */ (weeks || []);
const activeWeek = getCurrentOrLatestWeek(weekEntries);
const nextWeek = getNextWeek(weeks, currentSlug);
const nextWeekHref = nextWeek
  ? activeWeek && nextWeek.slug === activeWeek.slug
    ? baseUrl
    : `${baseUrl}week/${nextWeek.slug}`
  : null;

/**
 * @param {{name:string; category?:string; vbot?:string}[]} itemsToSummarize
 */
// @ts-ignore: implicit any is acceptable for this helper
const summarizeItems = (itemsToSummarize) => {
  const botSet = new Set();
  const weaponSet = new Set();
  const gearSet = new Set();

  for (const item of itemsToSummarize) {
    const cat = categorize(item);
    if (cat === 'chassis' || cat === 'torso' || cat === 'shoulder') {
      if (item.vbot) botSet.add(item.name);
    } else if (item.category?.toLowerCase().includes('weapon')) {
      weaponSet.add(item.name);
    } else if (item.category?.toLowerCase().includes('ability')) {
      gearSet.add(item.name);
    }
  }

  return {
    bots: Array.from(botSet).sort().join(', ') || '',
    weapons: Array.from(weaponSet).sort().join(', ') || '',
    gear: Array.from(gearSet).sort().join(', ') || '',
  };
};

const currentSummary = summarizeItems(items);

// Get summary for second latest week for meta descriptions
let secondWeekSummary = { bots: '', weapons: '', gear: '', dateRange: '' };
if (weekEntries.length > 1) {
  const secondWeek = weekEntries[1];
  if (secondWeek?.file) {
    const secondWeekData = fetchEnrichedDiscounts(secondWeek.file);
    secondWeekSummary = {
      ...summarizeItems(secondWeekData.items),
      dateRange: secondWeekData.dateRange || secondWeek.date_range || '',
    };
  }
}

const metaDescription = `${dateRange || 'Latest Discounts'}\nBots: ${currentSummary.bots}\nWeapons: ${currentSummary.weapons}\nGear: ${currentSummary.gear}` +
  (secondWeekSummary.dateRange ? `\n\n${secondWeekSummary.dateRange}\nBots: ${secondWeekSummary.bots}\nWeapons: ${secondWeekSummary.weapons}\nGear: ${secondWeekSummary.gear}` : '');

// Extract unique names for Discord embed
const vbots = new Set();
const weapons = new Set();
const gear = new Set();

for (const item of items) {
  const cat = categorize(item);
  if (cat === 'chassis' || cat === 'torso' || cat === 'shoulder') {
    // Bot parts - extract vbot name
    if (item.vbot) {
      vbots.add(item.name);
    }
  } else if (item.category?.toLowerCase().includes('weapon')) {
    weapons.add(item.name);
  } else if (item.category?.toLowerCase().includes('ability')) {
    gear.add(item.name);
  }
}

const botNames = Array.from(vbots).sort().join(', ');
const weaponNames = Array.from(weapons).sort().join(', ');
const gearNames = Array.from(gear).sort().join(', ');

const ogDescription = `${dateRange || 'Current Discounts'} - Bots: ${botNames || 'None'} | Weapons: ${weaponNames || 'None'} | Gear: ${gearNames || 'None'}`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>WRF Discounts</title>
		<link rel="stylesheet" href={`${baseUrl}global.css`} />
		
		<!-- Open Graph / Discord Embed -->
		<meta property="og:title" content="WRF Discounts" />
		<meta name="description" content={metaDescription} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="WRF Discounts" />
		<meta name="twitter:description" content={metaDescription} />
	</head>
	<body>
		<AllWeeksSidebar
			weeks={weeks}
			currentSlug={currentSlug}
			baseUrl={baseUrl}
			nextWeek={nextWeek}
			nextWeekHref={nextWeekHref}
		>
			<div class="app-content">
				<header>
					<h1>War Robots Frontiers Upgrade Discounts</h1>
					{dateRange && (
						<h3><strong>{dateRange}</strong></h3>
					)}
				</header>

				<DiscountGrid items={items} shopCards={shopCards} catIcons={catIcons} vbotMetaById={Astro.props.vbotMetaById} />

				<div class="discount-info">
					<p><img src={getTexturePath('/WRFrontiers/Content/Sparrow/UI/Textures/Meta/Currency/T_AlloysLarge', baseUrl)} class="currency-icon" alt="Salvage" /> Salvage is 50% reduced and <img src={getTexturePath('/WRFrontiers/Content/Sparrow/UI/Textures/Meta/Currency/T_IntelLarge', baseUrl)} class="currency-icon" alt="Intel" /> Intel is ~62% reduced</p>
				</div>
			</div>

			<div class="page-footer">
				<div class="footer-links">
					<DiscordFeedback />
					<GitHubHistory />
				</div>
				<LegalDisclaimer />
			</div>
		</AllWeeksSidebar>
	</body>
</html>

<style>
	:root {
		--bg-color: #0f1115;
		--sidebar-bg: #161920;
		--sidebar-border: #232733;
		--text-color: #e0e0e0;
		--text-muted: #8b92a5;
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
		--active-bg: rgba(58, 134, 255, 0.1);
	}

	body {
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Montserrat', sans-serif;
		margin: 0;
		padding: 0;
	}

	.app-content {
		flex: 1 0 auto;
		min-height: 100vh;
		box-sizing: border-box;
	}

	.discount-info {
		text-align: center;
		margin-top: 1rem;
	}

	.page-footer {
		flex-shrink: 0;
		padding-top: 3rem;
		padding-bottom: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	header {
		text-align: center;
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	h2 {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 4px;
		font-size: 1.25rem;
		/* slightly more grey than before */
		color: #bfbfbf;
		margin-bottom: 0.5rem;
	}

	.currency-icon {
		width: 20px;
		height: 20px;
		object-fit: contain;
		vertical-align: middle;
	}

	/* keep the date (inside <strong>) the main text color */
	header h2 strong {
		color: var(--text-color);
	}


	@media (max-width: 768px) {
		header {
			text-align: center;
		}

		h1 {
			font-size: 1.65rem;
			line-height: 1.2;
		}

		h2 {
			font-size: 0.95rem;
		}

		.currency-icon {
			width: 16px;
			height: 16px;
		}

	}

	@media (max-width: 480px) and (orientation: portrait) {
		h1 {
			font-size: 1.35rem;
		}

		h2 {
			font-size: 0.85rem;
		}
	}
</style>

---
import DiscountGrid from './grid/DiscountGrid.astro';
import DiscordFeedback from './DiscordFeedback.astro';
import LegalDisclaimer from './LegalDisclaimer.astro';
import AllWeeksSidebar from './AllWeeksSidebar.astro';
import GitHubHistory from './GitHubHistory.astro';
import { getTexturePath } from '../utils/textures.js';
import { categorize } from '../utils/gridData.js';
import { fetchEnrichedDiscounts } from '../utils/dataFetcher.js';
import { getCurrentOrLatestWeek, getNextWeek } from '../utils/dateValidator.js';

const { dateRange, gridData, shopCards, catIcons, weeks, currentSlug, vbotMetaById } = Astro.props;
const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
const weekEntries = /** @type {{date_range: string; file: string; slug: string;}[]} */ (weeks || []);
const mainPageWeek = weekEntries.length > 0 ? weekEntries[0] : null;
const nextWeek = getNextWeek(weeks, currentSlug);
const nextWeekHref = nextWeek
  ? mainPageWeek && nextWeek.slug === mainPageWeek.slug
    ? baseUrl
    : `${baseUrl}week/${nextWeek.slug}`
  : null;

const summarizeGrid = (grid, metaById) => {
  if (!grid) return { bots: '', weapons: '', gear: '' };
  const botSet = new Set();
  const weaponSet = new Set();
  const gearSet = new Set();

  const allRows = [...(grid.standardRows || []), ...(grid.titanRows || [])];
  for (const row of allRows) {
    if (row.botId && metaById && metaById[row.botId]) {
      botSet.add(metaById[row.botId].name);
    }
    
    if (row.cells["5"]) weaponSet.add(row.cells["5"].name);
    if (row.cells["6"]) weaponSet.add(row.cells["6"].name);
    
    if (row.cells["7"]) gearSet.add(row.cells["7"].name);
    if (row.cells["8"]) gearSet.add(row.cells["8"].name);
  }

  return {
    bots: Array.from(botSet).sort().join(', ') || '',
    weapons: Array.from(weaponSet).sort().join(', ') || '',
    gear: Array.from(gearSet).sort().join(', ') || '',
  };
};

const currentSummary = summarizeGrid(gridData, vbotMetaById);

// Get summary for second latest week for meta descriptions
let secondWeekSummary = { bots: '', weapons: '', gear: '', dateRange: '' };
if (weekEntries.length > 1) {
  const secondWeek = weekEntries[1];
  if (secondWeek?.file) {
    const secondWeekData = fetchEnrichedDiscounts(secondWeek.file);
    secondWeekSummary = {
      ...summarizeGrid(secondWeekData.gridData, secondWeekData.vbotMetaById),
      dateRange: secondWeekData.dateRange || secondWeek.date_range || '',
    };
  }
}

const metaDescription = `${dateRange || 'Latest Discounts'}\nBots: ${currentSummary.bots}\nWeapons: ${currentSummary.weapons}\nGear: ${currentSummary.gear}` +
  (secondWeekSummary.dateRange ? `\n\n${secondWeekSummary.dateRange}\nBots: ${secondWeekSummary.bots}\nWeapons: ${secondWeekSummary.weapons}\nGear: ${secondWeekSummary.gear}` : '');

const ogDescription = `${dateRange || 'Current Discounts'} - Bots: ${currentSummary.bots || 'None'} | Weapons: ${currentSummary.weapons || 'None'} | Gear: ${currentSummary.gear || 'None'}`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>WRF Discounts</title>
		<link rel="stylesheet" href={`${baseUrl}global.css`} />
		
		<!-- Open Graph / Discord Embed -->
		<meta property="og:title" content="WRF Discounts" />
		<meta name="description" content={metaDescription} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="https://surxe.github.io/WRFrontiers-Discount-Visualizer/discount-table.png" />
		<meta property="og:image:width" content="1400" />
		<meta property="og:image:height" content="900" />
		<meta property="og:image:alt" content="WRF Upgrade Discounts table" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="WRF Discounts" />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content="https://surxe.github.io/WRFrontiers-Discount-Visualizer/discount-table.png" />
	</head>
	<body>
		<AllWeeksSidebar
			weeks={weeks}
			currentSlug={currentSlug}
			baseUrl={baseUrl}
			nextWeek={nextWeek}
			nextWeekHref={nextWeekHref}
		>
			<div class="app-content">
				<header>
					<h1>War Robots Frontiers Upgrade Discounts</h1>
					{dateRange && (
						<h3><strong>{dateRange}</strong></h3>
					)}
				</header>

				<DiscountGrid gridData={gridData} shopCards={shopCards} catIcons={catIcons} vbotMetaById={vbotMetaById} />

				<div class="discount-info">
					<p><img src={getTexturePath('/WRFrontiers/Content/Sparrow/UI/Textures/Meta/Currency/T_AlloysLarge', baseUrl)} class="currency-icon" alt="Salvage" /> Salvage is 50% reduced and <img src={getTexturePath('/WRFrontiers/Content/Sparrow/UI/Textures/Meta/Currency/T_IntelLarge', baseUrl)} class="currency-icon" alt="Intel" /> Intel is ~62% reduced</p>
				</div>
			</div>

			<div class="page-footer">
				<div class="footer-links">
					<DiscordFeedback />
					<GitHubHistory />
				</div>
				<LegalDisclaimer />
			</div>
		</AllWeeksSidebar>
	</body>
</html>

<style>
	:root {
		--bg-color: #0f1115;
		--sidebar-bg: #161920;
		--sidebar-border: #232733;
		--text-color: #e0e0e0;
		--text-muted: #8b92a5;
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
		--active-bg: rgba(58, 134, 255, 0.1);
	}

	body {
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Montserrat', sans-serif;
		margin: 0;
		padding: 0;
	}

	.app-content {
		flex: 1 0 auto;
		min-height: 100vh;
		box-sizing: border-box;
	}

	.discount-info {
		text-align: center;
		margin-top: 1rem;
	}

	.page-footer {
		flex-shrink: 0;
		padding-top: 3rem;
		padding-bottom: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 2rem;
		margin-bottom: 2rem;
	}

	header {
		text-align: center;
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	h2 {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 4px;
		font-size: 1.25rem;
		/* slightly more grey than before */
		color: #bfbfbf;
		margin-bottom: 0.5rem;
	}

	.currency-icon {
		width: 20px;
		height: 20px;
		object-fit: contain;
		vertical-align: middle;
	}

	/* keep the date (inside <strong>) the main text color */
	header h2 strong {
		color: var(--text-color);
	}


	@media (max-width: 768px) {
		header {
			text-align: center;
		}

		h1 {
			font-size: 1.65rem;
			line-height: 1.2;
		}

		h2 {
			font-size: 0.95rem;
		}

		.currency-icon {
			width: 16px;
			height: 16px;
		}

	}

	@media (max-width: 480px) and (orientation: portrait) {
		h1 {
			font-size: 1.35rem;
		}

		h2 {
			font-size: 0.85rem;
		}
	}
</style>

---
import DiscountGrid from './grid/DiscountGrid.astro';
import DiscordFeedback from './DiscordFeedback.astro';
import LegalDisclaimer from './LegalDisclaimer.astro';
import AllWeeksSidebar from './AllWeeksSidebar.astro';
import { getTexturePath } from '../utils/textures.js';
import { categorize } from '../utils/gridData.js';
import { getCurrentOrLatestWeek, getNextWeek } from '../utils/dateValidator.js';

const { dateRange, items, shopCards, catIcons, weeks, currentSlug } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const activeWeek = getCurrentOrLatestWeek(weeks);
const nextWeek = getNextWeek(weeks, currentSlug);
const nextWeekHref = nextWeek
  ? activeWeek && nextWeek.slug === activeWeek.slug
    ? baseUrl
    : `${baseUrl}week/${nextWeek.slug}`
  : null;

// Extract unique names for Discord embed
const vbots = new Set();
const weapons = new Set();
const gear = new Set();

for (const item of items) {
  const cat = categorize(item);
  if (cat === 'chassis' || cat === 'torso' || cat === 'shoulder') {
    // Bot parts - extract vbot name
    if (item.vbot) {
      vbots.add(item.name);
    }
  } else if (item.category?.toLowerCase().includes('weapon')) {
    weapons.add(item.name);
  } else if (item.category?.toLowerCase().includes('ability')) {
    gear.add(item.name);
  }
}

const botNames = Array.from(vbots).sort().join(', ');
const weaponNames = Array.from(weapons).sort().join(', ');
const gearNames = Array.from(gear).sort().join(', ');

const ogDescription = `${dateRange || 'Current Discounts'} - Bots: ${botNames || 'None'} | Weapons: ${weaponNames || 'None'} | Gear: ${gearNames || 'None'}`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>War Robots Frontiers Discounts</title>
		<link rel="stylesheet" href={`${baseUrl}global.css`} />
		
		<!-- Open Graph / Discord Embed -->
		<meta property="og:title" content="War Robots Frontiers Discounts" />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="War Robots Frontiers Discounts" />
		<meta name="twitter:description" content={ogDescription} />
	</head>
	<body>
		<AllWeeksSidebar
			weeks={weeks}
			currentSlug={currentSlug}
			baseUrl={baseUrl}
			nextWeek={nextWeek}
			nextWeekHref={nextWeekHref}
		>
			<div class="app-content">
				<header>
					<h1>War Robots Frontiers Discounts</h1>
					{dateRange && (
						<h2>
							Salvage <img src={getTexturePath('/WRFrontiers/Content/Sparrow/UI/Textures/Meta/Currency/T_AlloysLarge', baseUrl)} class="currency-icon" alt="Salvage" /> and Intel <img src={getTexturePath('/WRFrontiers/Content/Sparrow/UI/Textures/Meta/Currency/T_IntelLarge', baseUrl)} class="currency-icon" alt="Intel" /> Discounts  -  <strong>{dateRange}</strong>
						</h2>
					)}
				</header>

				<DiscountGrid items={items} shopCards={shopCards} catIcons={catIcons} vbotMetaById={Astro.props.vbotMetaById} />

				<div class="discount-info">
					<p>Salvage is 50% reduced and Intel is ~62% reduced</p>
				</div>
			</div>

			<div class="page-footer">
				<DiscordFeedback />
				<LegalDisclaimer />
			</div>
		</AllWeeksSidebar>
	</body>
</html>

<style>
	:root {
		--bg-color: #0f1115;
		--sidebar-bg: #161920;
		--sidebar-border: #232733;
		--text-color: #e0e0e0;
		--text-muted: #8b92a5;
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
		--active-bg: rgba(58, 134, 255, 0.1);
	}

	body {
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Montserrat', sans-serif;
		margin: 0;
		padding: 0;
	}

	.app-content {
		flex: 1 0 auto;
		min-height: 100vh;
		box-sizing: border-box;
	}

	.discount-info {
		text-align: center;
		margin-top: 1rem;
	}

	.page-footer {
		flex-shrink: 0;
		padding-top: 3rem;
		padding-bottom: 2rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	header {
		text-align: center;
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	h2 {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 4px;
		font-size: 1.25rem;
		margin-bottom: 0.5rem;
	}

	.currency-icon {
		width: 20px;
		height: 20px;
		object-fit: contain;
		vertical-align: middle;
	}


	@media (max-width: 768px) {
		header {
			text-align: center;
		}

		h1 {
			font-size: 1.65rem;
			line-height: 1.2;
		}

		h2 {
			font-size: 0.95rem;
		}

		.currency-icon {
			width: 16px;
			height: 16px;
		}

	}

	@media (max-width: 480px) and (orientation: portrait) {
		h1 {
			font-size: 1.35rem;
		}

		h2 {
			font-size: 0.85rem;
		}
	}
</style>

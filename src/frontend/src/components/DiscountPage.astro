---
import DiscountGrid from './grid/DiscountGrid.astro';
import DiscountInfo from './DiscountInfo.astro';
import AllWeeksSidebar from './AllWeeksSidebar.astro';
import WeekNavigation from './WeekNavigation.astro';
import Footer from './Footer.astro';
import NavBar from './NavBar.astro';
import LastDiscountTable from './LastDiscountTable.astro';
import CostCalculator from './CostCalculator.astro';
import { getTexturePath, getRarityBackgroundUrl } from '../utils/textures.js';
import { categorize } from '../utils/gridData.js';
import { fetchEnrichedDiscounts } from '../utils/dataFetcher.js';
import { fetchModules, fetchModuleRarities, getModuleDisplayName } from '../utils/moduleData.js';
import { fetchDiscountHistory } from '../utils/discountHistory.js';
import { getCurrentOrLatestWeek, getNextWeek, getPreviousWeek } from '../utils/dateValidator.js';
import { formatWeek } from '../utils/weekDates.js';
import { extractDiscountedItemsFromGrid } from '../utils/discountHistory.js';
import fs from 'fs';
import path from 'path';

const { dateRange, gridData, shopCards, catIcons, weeks, currentSlug, vbotMetaById } = Astro.props;
const baseUrl = /** @type {string} */ ((import.meta as any).env?.BASE_URL) || '/';
const weekEntries = /** @type {{week?: object; date_range?: string; file: string; slug: string;}[]} */ (weeks || []);
const mainPageWeek = weekEntries.length > 0 ? weekEntries[0] : null;
const nextWeek = getNextWeek(weeks, currentSlug);
const nextWeekHref = nextWeek
  ? mainPageWeek && nextWeek.slug === mainPageWeek.slug
    ? baseUrl
    : `${baseUrl}week/${nextWeek.slug}`
  : null;
const prevWeek = getPreviousWeek(weeks, currentSlug);
const prevWeekHref = prevWeek
  ? mainPageWeek && prevWeek.slug === mainPageWeek.slug
    ? baseUrl
    : `${baseUrl}week/${prevWeek.slug}`
  : null;

const summarizeGrid = (grid, metaById) => {
  if (!grid) return { bots: '', weapons: '', gear: '' };
  const botSet = new Set();
  const weaponSet = new Set();
  const gearSet = new Set();

  const allRows = [...(grid.standardRows || []), ...(grid.titanRows || [])];
  for (const row of allRows) {
    if (row.botId && metaById && metaById[row.botId]) {
      botSet.add(metaById[row.botId].name);
    }
    
    if (row.cells["5"]) weaponSet.add(row.cells["5"].name);
    if (row.cells["6"]) weaponSet.add(row.cells["6"].name);
    
    if (row.cells["7"]) gearSet.add(row.cells["7"].name);
    if (row.cells["8"]) gearSet.add(row.cells["8"].name);
  }

  return {
    bots: Array.from(botSet).sort().join(', ') || '',
    weapons: Array.from(weaponSet).sort().join(', ') || '',
    gear: Array.from(gearSet).sort().join(', ') || '',
  };
};

const currentSummary = summarizeGrid(gridData, vbotMetaById);

// Get summary for second latest week for meta descriptions
let secondWeekSummary = { bots: '', weapons: '', gear: '', dateRange: '' };
if (weekEntries.length > 1) {
  const secondWeek = weekEntries[1];
  if (secondWeek?.file) {
    const secondWeekData = fetchEnrichedDiscounts(secondWeek.file);
    secondWeekSummary = {
      ...summarizeGrid(secondWeekData.gridData, secondWeekData.vbotMetaById),
      dateRange: secondWeekData.dateRange || formatWeek(secondWeek, 'long') || secondWeek.date_range || '',
    };
  }
}

const metaDescription = `${dateRange || 'Latest Discounts'}\nBots: ${currentSummary.bots}\nWeapons: ${currentSummary.weapons}\nGear: ${currentSummary.gear}` +
  (secondWeekSummary.dateRange ? `\n\n${secondWeekSummary.dateRange}\nBots: ${secondWeekSummary.bots}\nWeapons: ${secondWeekSummary.weapons}\nGear: ${secondWeekSummary.gear}` : '');

// Extract items from grid data for last discount table
const discountedItems = extractDiscountedItemsFromGrid(gridData, currentSlug);

const imageSha = import.meta.env.PUBLIC_IMAGE_SHA;
const imageFilename = imageSha ? `discount-table-${imageSha}.png` : 'discount-table.png';

// Build searchable modules for Cost Calculator
const allModulesRaw = fetchModules() || {};
const moduleRaritiesRaw = fetchModuleRarities() || {};

const parseRef = (ref) => {
  if (!ref) return null;
  const parts = ref.split('::');
  return parts.length > 1 ? parts[1] : parts[0];
};

const searchableModules = Object.values(allModulesRaw)
  .filter(m => m.production_status === 'Ready')
  .map(m => {
    const rawRarityRef = parseRef(m.module_rarity_ref);
    const moduleRarity = moduleRaritiesRaw[rawRarityRef];
    const baseRarityRef = moduleRarity ? parseRef(moduleRarity.rarity_ref) : null;
    
    return {
      id: m.id,
      name: getModuleDisplayName(m),
      iconSrc: getTexturePath(m.inventory_icon_path, baseUrl) || '',
      bgSrc: getRarityBackgroundUrl(baseRarityRef, shopCards, baseUrl) || '',
      rarityRef: m.module_rarity_ref
    };
  })
  .sort((a, b) => a.name.localeCompare(b.name));

// --- RarityUpgradeCosts ---
let rarityUpgradeCosts = {};
try {
  const ruPath = [
    path.resolve('../../WRFrontiersDB-Data/current/Objects/RarityUpgradeCost.json'),
    path.resolve('../../../WRFrontiersDB-Data/current/Objects/RarityUpgradeCost.json'),
    path.resolve('public/WRFrontiersDB-Data/current/Objects/RarityUpgradeCost.json'),
  ].find(p => fs.existsSync(p));
  if (ruPath) rarityUpgradeCosts = JSON.parse(fs.readFileSync(ruPath, 'utf-8'));
} catch (e) { console.error('Failed to load RarityUpgradeCost.json', e); }

// --- Discount Schedule: weekSlug -> [moduleId, ...] ---
const discountHistory = fetchDiscountHistory();
const discountSchedule = {};
for (const [ref, data] of Object.entries(discountHistory.modules || {})) {
  const moduleId = ref.startsWith('OBJID_Module::') ? ref.slice('OBJID_Module::'.length) : ref;
  const weeks = Array.isArray(data) ? data : (data?.weeks || []);
  for (const weekSlug of weeks) {
    if (!discountSchedule[weekSlug]) discountSchedule[weekSlug] = [];
    discountSchedule[weekSlug].push(moduleId);
  }
}

// --- Week List for the selector ---
const weekList = weekEntries.map(w => ({
  slug: w.slug,
  label: formatWeek(w, 'short') || w.date_range || w.slug,
}));
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>WRF Discounts</title>
		<link rel="stylesheet" href={`${baseUrl}global.css`} />
		
		<!-- Open Graph / Discord Embed -->
		<meta property="og:title" content="WRF Discounts" />
		<meta name="description" content={metaDescription} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content={`https://surxe.github.io/WRFrontiers-Discount-Visualizer/${imageFilename}`} />
		<meta property="og:image:width" content="1300" />
		<meta property="og:image:height" content="900" />
		<meta property="og:image:alt" content="WRF Upgrade Discounts table" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="WRF Discounts" />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content={`https://surxe.github.io/WRFrontiers-Discount-Visualizer/${imageFilename}`} />
	</head>
	<body>
		<AllWeeksSidebar
			weeks={weeks}
			currentSlug={currentSlug}
			baseUrl={baseUrl}
			nextWeek={nextWeek}
			nextWeekHref={nextWeekHref}
		>
			<div class="app-content">
				<NavBar baseUrl={baseUrl} currentPage="home" />
				
				<button id="calculator-toggle" class="calculator-toggle" aria-label="Open Calculator">
					<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
						<line x1="16" y1="2" x2="16" y2="6"></line>
						<line x1="8" y1="2" x2="8" y2="6"></line>
						<line x1="4" y1="10" x2="20" y2="10"></line>
						<line x1="8" y1="14" x2="12" y2="14"></line>
						<line x1="12" y1="14" x2="12" y2="18"></line>
						<line x1="12" y1="18" x2="8" y2="18"></line>
						<line x1="8" y1="18" x2="8" y2="14"></line>
						<line x1="16" y1="14" x2="16" y2="14.01"></line>
						<line x1="16" y1="18" x2="16" y2="18.01"></line>
					</svg>
					<span id="calculator-badge" class="calculator-badge" style="display: none;">0</span>
				</button>

				<header>
					<h1>War Robots Frontiers Upgrade Discounts</h1>
					{dateRange && (
						<div class="date-nav-wrapper">
							<WeekNavigation prevWeekHref={prevWeekHref} nextWeekHref={nextWeekHref} />
						</div>
					)}
				</header>

				<DiscountGrid dateRange={dateRange} gridData={gridData} shopCards={shopCards} catIcons={catIcons} vbotMetaById={vbotMetaById} currentWeekSlug={currentSlug} />

				<LastDiscountTable items={discountedItems} currentWeekSlug={currentSlug} baseUrl={baseUrl} />

				<DiscountInfo currentSlug={currentSlug} baseUrl={baseUrl} />
			</div>

		<Footer />
		</AllWeeksSidebar>
		
		<CostCalculator
			searchableModules={searchableModules}
			rarityUpgradeCosts={rarityUpgradeCosts}
			discountSchedule={discountSchedule}
			weekList={weekList}
			currentWeekSlug={currentSlug}
		/>
	</body>
</html>

<script>
	import { calculatorStore } from '../scripts/cost-calculator-store.js';

	const toggleBtn = document.getElementById('calculator-toggle');
	const badge = document.getElementById('calculator-badge');

	if (toggleBtn) {
		toggleBtn.addEventListener('click', () => {
			calculatorStore.toggleDrawer();
		});
	}

	calculatorStore.addEventListener('change', (e) => {
		const { shoppingList, isOpen } = e.detail;
		
		if (isOpen) {
			document.body.classList.add('calc-open');
		} else {
			document.body.classList.remove('calc-open');
		}

		if (badge) {
			const totalQty = shoppingList.reduce((sum, item) => sum + item.quantity, 0);
			if (totalQty > 0) {
				badge.textContent = String(totalQty);
				badge.style.display = 'flex';
			} else {
				badge.style.display = 'none';
			}
		}
	});
</script>

<style>
	:root {
		--bg-color: #0f1115;
		--sidebar-bg: #161920;
		--sidebar-border: #232733;
		--text-color: #e0e0e0;
		--text-muted: #8b92a5;
		--accent-color: #3a86ff;
		--accent-hover: #2b65cc;
		--active-bg: rgba(58, 134, 255, 0.1);
	}

	body {
		background-color: var(--bg-color);
		color: var(--text-color);
		font-family: 'Montserrat', sans-serif;
		margin: 0;
		padding: 0;
		transition: padding-right 0.3s ease;
	}

	.app-content {
		flex: 1 0 auto;
		min-height: 100vh;
		box-sizing: border-box;
		position: relative;
	}

	@media (min-width: 1024px) {
		body.calc-open {
			padding-right: 500px;
		}
	}

	.calculator-toggle {
		position: absolute;
		top: 1rem;
		right: 1.5rem;
		background: #232733;
		border: 1px solid #333;
		color: #e0e0e0;
		border-radius: 8px;
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		z-index: 9000;
		transition: all 0.3s ease;
	}

	.calculator-toggle:hover {
		background-color: var(--active-bg);
		color: var(--accent-color);
	}

	.calculator-badge {
		position: absolute;
		top: -5px;
		right: -5px;
		background: #ef233c;
		color: white;
		font-size: 0.7rem;
		font-weight: bold;
		width: 18px;
		height: 18px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	header {
		text-align: center;
		margin-bottom: 1.5rem;
	}

	h1 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	h2 {
		display: flex;
		align-items: center;
		justify-content: center;
		flex-wrap: wrap;
		gap: 4px;
		font-size: 1.25rem;
		/* slightly more grey than before */
		color: #bfbfbf;
		margin-bottom: 0.5rem;
	}

	h3.date-header {
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0.5rem 0;
	}

	/* keep the date (inside <strong>) the main text color */
	header h2 strong {
		color: var(--text-color);
	}

	.date-nav-wrapper {
		display: flex;
		justify-content: center;
		margin: 0.5rem 0 1rem;
	}


	@media (max-width: 768px) {
		header {
			text-align: center;
		}

		h1 {
			font-size: 1.65rem;
			line-height: 1.2;
		}

		h2 {
			font-size: 0.95rem;
		}

	}

	@media (max-width: 480px) and (orientation: portrait) {
		h1 {
			font-size: 1.35rem;
		}

		h2 {
			font-size: 0.85rem;
		}
	}
</style>

---
const { style: inlineStyle, span } = Astro.props;
const spanStyle = span ? `grid-column: span ${span};` : '';
---

<div class="empty-cell" style={[spanStyle, inlineStyle].filter(Boolean).join(' ')}></div>

<style>
  .empty-cell {
    height: var(--module-cell-height);
    box-sizing: border-box;
  }
</style>

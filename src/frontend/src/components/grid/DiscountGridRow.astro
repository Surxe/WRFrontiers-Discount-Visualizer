---
import ModulesBox from '../module/ModulesBox.astro';
import ModuleBox from '../module/ModuleBox.astro';
import EmptyCell from './EmptyCell.astro';

const {
  bot,
  lightWep,
  heavyWep,
  supply,
  cycle,
  shopCards,
  titanWeapon,
  variant = 'standard',
} = Astro.props;

const botModules = bot
  ? [...bot.torso, ...bot.shoulder, ...bot.chassis]
  : [];
---

<div class="grid-row contents">
  {variant === 'standard' && (
    <>
      {bot ? (
        <ModulesBox
          modules={botModules}
          shopCards={shopCards}
          style="grid-column: 1 / 4;"
        />
      ) : (
        <EmptyCell style="grid-column: 1 / 4;" />
      )}

      {lightWep ? (
        <ModuleBox module={lightWep} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {heavyWep ? (
        <ModuleBox module={heavyWep} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {supply ? (
        <ModuleBox module={supply} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {cycle ? (
        <ModuleBox module={cycle} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
    </>
  )}

  {variant === 'titan' && (
    <>
      {bot ? (
        <ModulesBox
          modules={botModules}
          shopCards={shopCards}
          style="grid-column: 1 / 4;"
        />
      ) : (
        <EmptyCell style="grid-column: 1 / 4;" />
      )}

      {titanWeapon ? (
        <ModuleBox
          module={titanWeapon}
          shopCards={shopCards}
          wide
          style="grid-column: 4 / 6;"
        />
      ) : (
        <EmptyCell style="grid-column: 4 / 6;" />
      )}

      <EmptyCell />
      <EmptyCell />
    </>
  )}
</div>

<style>
  .contents {
    display: contents;
  }
</style>

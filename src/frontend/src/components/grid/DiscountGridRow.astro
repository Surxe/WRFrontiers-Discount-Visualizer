---
import ObjectBox from '../module/ObjectBox.astro';
import ModulesBox from '../module/ModulesBox.astro';
import EmptyCell from './EmptyCell.astro';

const {
  bot,
  lightWep,
  heavyWep,
  supply,
  cycle,
  shopCards,
  titanWeapon,
  variant = 'standard',
  sidebarLabel,
  sectionTopDivider = false,
} = Astro.props;
---

<div class:list={['grid-row', { 'grid-row--section-top': sectionTopDivider }]}>
  {variant === 'standard' && (
    <>
      {sidebarLabel ? (
        <div class="sidebar-cell"><span>{sidebarLabel}</span></div>
      ) : (
        <EmptyCell />
      )}
      {bot ? (
        <>
          <ObjectBox
            module={{
              icon_path: bot.icon_path,
              name: bot.name,
              rarity: bot.rarity,
              faction_icon_path: bot.faction_icon_path,
              class_icon_path: bot.class_icon_path,
            }}
            shopCards={shopCards}
            showName={true}
            showBadges={true}
          />
          <ModulesBox modules={[bot.torso[0], bot.shoulder[0], bot.chassis[0]]} shopCards={shopCards} />
        </>
      ) : (
        <>
          <EmptyCell />
          <EmptyCell span={3} />
        </>
      )}

      <div class="grid-spacer"></div>

      {lightWep ? (
        <ObjectBox module={lightWep} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {heavyWep ? (
        <ObjectBox module={heavyWep} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {supply ? (
        <ObjectBox module={supply} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {cycle ? (
        <ObjectBox module={cycle} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
    </>
  )}

  {variant === 'titan' && (
    <>
      {sidebarLabel ? (
        <div class="sidebar-cell"><span>{sidebarLabel}</span></div>
      ) : (
        <EmptyCell />
      )}
      {bot ? (
        <>
          <ObjectBox
            module={{
              icon_path: bot.icon_path,
              name: bot.name,
              rarity: bot.rarity,
              faction_icon_path: bot.faction_icon_path,
              class_icon_path: bot.class_icon_path,
            }}
            shopCards={shopCards}
            showName={true}
            showBadges={true}
          />
          <ModulesBox modules={[bot.torso[0], bot.shoulder[0], bot.chassis[0]]} shopCards={shopCards} />
        </>
      ) : (
        <>
          <EmptyCell />
          <EmptyCell span={3} />
        </>
      )}

      <div class="grid-spacer"></div>

      {titanWeapon ? (
        <ObjectBox
          module={titanWeapon}
          shopCards={shopCards}
        />
      ) : (
        <EmptyCell />
      )}

      <EmptyCell />
      <EmptyCell />
      <EmptyCell />
      <EmptyCell />
    </>
  )}
</div>

<style>
  .grid-row {
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: subgrid;
    box-sizing: border-box;
    height: 100%;
  }

  .grid-row--section-top {
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    padding-top: calc(10px * var(--grid-scale, 1));
  }

  .sidebar-cell {
    position: relative;
    height: 100%;
    overflow: visible;
  }

  .sidebar-cell span {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: var(--sidebar-label-font-size, calc(var(--module-cell-height, 119px) / 10));
    text-transform: uppercase;
    letter-spacing: var(--sidebar-label-letter-spacing, 0.04em);
    writing-mode: vertical-rl;
    text-orientation: upright;
    pointer-events: none;
    line-height: 1;
  }
</style>

---
import ObjectBox from '../module/ObjectBox.astro';
import EmptyCell from './EmptyCell.astro';

const {
  bot,
  lightWep,
  heavyWep,
  supply,
  cycle,
  shopCards,
  titanWeapon,
  variant = 'standard',
} = Astro.props;
---

<div class="grid-row contents">
  {variant === 'standard' && (
    <>
      {bot ? (
        <>
          <ObjectBox
            module={{
              icon_path: bot.icon_path,
              name: bot.name,
              rarity: bot.rarity
            }}
            shopCards={shopCards}
            showName={true}
          />
          <ObjectBox module={bot.torso[0]} shopCards={shopCards} showName={false} />
          <ObjectBox module={bot.shoulder[0]} shopCards={shopCards} showName={false} />
          <ObjectBox module={bot.chassis[0]} shopCards={shopCards} showName={false} />
        </>
      ) : (
        <>
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
        </>
      )}

      <div class="grid-spacer"></div>

      {lightWep ? (
        <ObjectBox module={lightWep} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {heavyWep ? (
        <ObjectBox module={heavyWep} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {supply ? (
        <ObjectBox module={supply} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {cycle ? (
        <ObjectBox module={cycle} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
    </>
  )}

  {variant === 'titan' && (
    <>
      {bot ? (
        <>
          <ObjectBox
            module={{
              icon_path: bot.icon_path,
              name: bot.name,
              rarity: bot.rarity
            }}
            shopCards={shopCards}
            showName={true}
          />
          <ObjectBox module={bot.torso[0]} shopCards={shopCards} showName={false} />
          <ObjectBox module={bot.shoulder[0]} shopCards={shopCards} showName={false} />
          <ObjectBox module={bot.chassis[0]} shopCards={shopCards} showName={false} />
        </>
      ) : (
        <>
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
        </>
      )}

      <div class="grid-spacer"></div>

      {titanWeapon ? (
        <ObjectBox
          module={titanWeapon}
          shopCards={shopCards}
        />
      ) : (
        <EmptyCell />
      )}

      <EmptyCell />
      <EmptyCell />
      <EmptyCell />
    </>
  )}
</div>

<style>
  .contents {
    display: contents;
  }
</style>

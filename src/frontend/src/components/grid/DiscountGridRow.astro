---
import ObjectBox from '../module/ObjectBox.astro';
import EmptyCell from './EmptyCell.astro';

const {
  bot,
  lightWep,
  heavyWep,
  supply,
  cycle,
  shopCards,
  titanWeapon,
  variant = 'standard',
  sidebarLabel,
} = Astro.props;
---

<div class="grid-row contents">
  {variant === 'standard' && (
    <>
      {sidebarLabel ? (
        <div class="sidebar-cell"><span>{sidebarLabel}</span></div>
      ) : (
        <EmptyCell />
      )}
      {bot ? (
        <>
          <ObjectBox
            module={{
              icon_path: bot.icon_path,
              name: bot.name,
              rarity: bot.rarity,
              faction_icon_path: bot.faction_icon_path,
              class_icon_path: bot.class_icon_path,
            }}
            shopCards={shopCards}
            showName={true}
            showBadges={true}
          />
          <ObjectBox module={bot.torso[0]} shopCards={shopCards} showName={false} />
          <ObjectBox module={bot.shoulder[0]} shopCards={shopCards} showName={false} />
          <ObjectBox module={bot.chassis[0]} shopCards={shopCards} showName={false} />
        </>
      ) : (
        <>
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
        </>
      )}

      <div class="grid-spacer"></div>

      {lightWep ? (
        <ObjectBox module={lightWep} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {heavyWep ? (
        <ObjectBox module={heavyWep} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {supply ? (
        <ObjectBox module={supply} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
      {cycle ? (
        <ObjectBox module={cycle} shopCards={shopCards} />
      ) : (
        <EmptyCell />
      )}
    </>
  )}

  {variant === 'titan' && (
    <>
      {sidebarLabel ? (
        <div class="sidebar-cell"><span>{sidebarLabel}</span></div>
      ) : (
        <EmptyCell />
      )}
      {bot ? (
        <>
          <ObjectBox
            module={{
              icon_path: bot.icon_path,
              name: bot.name,
              rarity: bot.rarity,
              faction_icon_path: bot.faction_icon_path,
              class_icon_path: bot.class_icon_path,
            }}
            shopCards={shopCards}
            showName={true}
            showBadges={true}
          />
          <ObjectBox module={bot.torso[0]} shopCards={shopCards} showName={false} />
          <ObjectBox module={bot.shoulder[0]} shopCards={shopCards} showName={false} />
          <ObjectBox module={bot.chassis[0]} shopCards={shopCards} showName={false} />
        </>
      ) : (
        <>
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
          <EmptyCell />
        </>
      )}

      <div class="grid-spacer"></div>

      {titanWeapon ? (
        <ObjectBox
          module={titanWeapon}
          shopCards={shopCards}
        />
      ) : (
        <EmptyCell />
      )}

      <EmptyCell />
      <EmptyCell />
      <EmptyCell />
      <EmptyCell />
    </>
  )}
</div>

<style>
  .contents {
    display: contents;
  }

  .sidebar-cell {
    position: relative;
    height: 100%;
    overflow: visible;
  }

  .sidebar-cell span {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: var(--sidebar-label-font-size, calc(var(--module-cell-height, 119px) / 10));
    text-transform: uppercase;
    letter-spacing: var(--sidebar-label-letter-spacing, 0.04em);
    writing-mode: vertical-rl;
    text-orientation: upright;
    pointer-events: none;
    line-height: 1;
  }
</style>

---
import GridHeader from './GridHeader.astro';
import DiscountGridRow from './DiscountGridRow.astro';

const { gridData, shopCards, catIcons, vbotMetaById = {} } = Astro.props;

const standardRows = gridData?.standardRows || [];
const titanRows = gridData?.titanRows || [];

// Helper to construct bot object expected by DiscountGridRow
function buildBot(botId, cells) {
  if (!botId) return null;
  const meta = vbotMetaById[botId] || {};
  return {
    icon_path: meta.icon_path,
    name: meta.name,
    rarity: meta.rarity,
    faction_icon_path: meta.faction_icon_path,
    class_icon_path: meta.class_icon_path,
    torso: [cells["1"]],
    shoulder: [cells["2"]],
    chassis: [cells["3"]]
  };
}
---

<div class="grid-scale-host">
<div class="grid-container" id="discount-grid">
  <GridHeader catIcons={catIcons} />

  {standardRows.map((row, i) => (
    <DiscountGridRow
      bot={buildBot(row.botId, row.cells)}
      lightWep={row.cells["4"]}
      heavyWep={row.cells["5"]}
      supply={row.cells["6"]}
      cycle={row.cells["7"]}
      shopCards={shopCards}
      variant="standard"
      sidebarLabel={i === Math.floor((standardRows.length - 1) / 2) ? 'Mechs' : null}
    />
  ))}

  {titanRows.length > 0 ? (
    <>
      {titanRows.map((row, i) => (
        <DiscountGridRow
          bot={buildBot(row.botId, row.cells)}
          titanWeapon={row.cells["4"]}
          shopCards={shopCards}
          variant="titan"
          sidebarLabel={i === Math.floor((titanRows.length - 1) / 2) ? 'Titans' : null}
          sectionTopDivider={standardRows.length > 0 && i === 0}
        />
      ))}
    </>
  ) : null}
</div>
</div>

<style>
  /* Intrinsic width at scale 1: columns + gaps + horizontal padding */
  .grid-scale-host {
    --grid-intrinsic-width: 938px;
    /* 8 module cols @ 100px each (scale 1 reference width) */
    --grid-module-cols-width: 800px;
    container-type: inline-size;
    container-name: discount-grid;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .grid-container {
    --grid-scale: min(1, calc((100cqi - 0.5rem) / var(--grid-intrinsic-width)));
    --module-col: calc(100px * var(--grid-scale));
    --grid-sidebar-col: calc(34px * var(--grid-scale));
    --grid-divider-col: calc(13px * var(--grid-scale));
    --grid-col-gap: calc(7px * var(--grid-scale));
    --grid-row-gap: calc(13px * var(--grid-scale));
    --grid-padding: calc(14px * var(--grid-scale));
    --module-icon-max-height: calc(80px * var(--grid-scale));
    --module-name-strip: calc(29px * var(--grid-scale));
    --module-card-padding: calc(5px * var(--grid-scale));
    --module-card-padding-x: calc(7px * var(--grid-scale));
    --module-card-radius: calc(8px * var(--grid-scale));
    --module-name-font: calc(13.6px * var(--grid-scale));
    --footer-icon-size: calc(11px * var(--grid-scale));
    --grid-header-height: calc(60px * var(--grid-scale));
    --grid-header-font: calc(13.6px * var(--grid-scale));
    --grid-header-icon: calc(30px * var(--grid-scale));
    --sidebar-label-letter-spacing: calc(0.02em * var(--grid-scale));
    /* Upright stack: ~6 letters tall + narrow column */
    --sidebar-label-font-size: min(
      calc(var(--module-cell-height) / 10),
      calc(var(--grid-sidebar-col) * 0.68)
    );
    --module-card-height: calc(
      var(--module-icon-max-height) + 2 * var(--module-card-padding) + var(--module-name-strip) + calc(6px * var(--grid-scale))
    );
    --module-cell-height: var(--module-card-height);
    display: grid;
    grid-template-columns:
      var(--grid-sidebar-col)
      repeat(4, var(--module-col))
      var(--grid-divider-col)
      repeat(4, var(--module-col));
    grid-template-rows: auto;
    grid-auto-rows: var(--module-cell-height);
    column-gap: var(--grid-col-gap);
    row-gap: var(--grid-row-gap);
    background: #15181e;
    padding: var(--grid-padding);
    border-radius: calc(12px * var(--grid-scale));
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    width: fit-content;
    max-width: 100%;
    margin-inline: auto;
    box-sizing: border-box;
  }

  @supports not (container-type: inline-size) {
    .grid-container {
      --grid-scale: min(1, calc((100vw - 3.5rem) / var(--grid-intrinsic-width)));
    }

    @media (max-width: 640px) {
      .grid-container {
        --grid-sidebar-base: 18px;
        --grid-divider-base: 9px;
        --grid-static-overhead: 2.25rem;
        --grid-scale: min(
          1,
          calc((100vw - 3.5rem - var(--grid-static-overhead)) / var(--grid-module-cols-width))
        );
        --grid-sidebar-col: calc(var(--grid-sidebar-base) * var(--grid-scale));
        --grid-divider-col: calc(var(--grid-divider-base) * var(--grid-scale));
        width: 100%;
        grid-template-columns:
          var(--grid-sidebar-col)
          repeat(4, minmax(0, 1fr))
          var(--grid-divider-col)
          repeat(4, minmax(0, 1fr));
      }
    }
  }

  /* Thin viewports: fill width, shrink label gutter, scale from module column budget */
  @container discount-grid (max-width: 640px) {
    .grid-container {
      --grid-sidebar-base: 18px;
      --grid-divider-base: 9px;
      --grid-static-overhead: 2.25rem;
      --grid-scale: min(
        1,
        calc((100cqi - var(--grid-static-overhead)) / var(--grid-module-cols-width))
      );
      --grid-sidebar-col: calc(var(--grid-sidebar-base) * var(--grid-scale));
      --grid-divider-col: calc(var(--grid-divider-base) * var(--grid-scale));
      width: 100%;
      grid-template-columns:
        var(--grid-sidebar-col)
        repeat(4, minmax(0, 1fr))
        var(--grid-divider-col)
        repeat(4, minmax(0, 1fr));
    }
  }

  @container discount-grid (max-width: 480px) {
    .grid-container {
      --sidebar-label-font-size: min(
        calc(var(--module-cell-height) / 16),
        calc(var(--grid-sidebar-col) * 0.45)
      );
      --sidebar-label-letter-spacing: 0;
    }
  }

  @media (max-width: 768px) {
    .grid-container {
      --sidebar-label-font-size: min(
        calc(var(--module-cell-height) / 16),
        calc(var(--grid-sidebar-col) * 0.45)
      );
      --sidebar-label-letter-spacing: 0;
    }
  }

</style>

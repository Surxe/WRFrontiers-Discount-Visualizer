---
import GridHeader from './GridHeader.astro';
import DiscountGridRow from './DiscountGridRow.astro';
import {
  isTitan,
  categorize,
  processBots,
  getWeaponAndGear,
  assignWeaponTypeToBots,
  countStandardRows,
  countTitanRows,
} from '../../utils/gridData.js';

const { items, shopCards, catIcons, vbotMetaById = {} } = Astro.props;

const standardItems = items.filter((i) => !isTitan(i));
const titanItems = items.filter((i) => isTitan(i));

const standardBots = processBots(standardItems, vbotMetaById);
const titanBots = titanItems.length > 0 ? processBots(titanItems, vbotMetaById) : [];
const stdWeapons = getWeaponAndGear(standardItems);
const titanWeapons = titanItems.length > 0 ? titanItems.filter((i) => categorize(i) === null) : [];

// Assign weapons to their preferred bot rows
const assignedLightWep = assignWeaponTypeToBots(standardBots, stdWeapons.lightWep);
const assignedHeavyWep = assignWeaponTypeToBots(standardBots, stdWeapons.heavyWep);
const assignedSupply = assignWeaponTypeToBots(standardBots, stdWeapons.supply);
const assignedCycle = assignWeaponTypeToBots(standardBots, stdWeapons.cycle);
const assignedTitanWeapons = assignWeaponTypeToBots(titanBots, titanWeapons);

const stdRows = countStandardRows(standardBots, stdWeapons);
const titanRows = countTitanRows(titanBots, titanWeapons);
---

<div class="grid-scale-host">
<div class="grid-container">
  <GridHeader catIcons={catIcons} />

  {Array.from({ length: stdRows }).map((_, i) => (
    <DiscountGridRow
      bot={standardBots[i]}
      lightWep={assignedLightWep[i]}
      heavyWep={assignedHeavyWep[i]}
      supply={assignedSupply[i]}
      cycle={assignedCycle[i]}
      shopCards={shopCards}
      variant="standard"
      sidebarLabel={i === Math.floor((stdRows - 1) / 2) ? 'Mechs' : null}
    />
  ))}

  {titanItems.length > 0 && titanRows > 0 ? (
    <>
      {Array.from({ length: titanRows }).map((_, i) => (
        <DiscountGridRow
          bot={titanBots[i]}
          titanWeapon={assignedTitanWeapons[i]}
          shopCards={shopCards}
          variant="titan"
          sidebarLabel={i === 0 ? 'Titans' : null}
          sectionTopDivider={stdRows > 0 && i === 0}
        />
      ))}
    </>
  ) : null}
</div>
</div>

<style>
  /* Intrinsic width at scale 1: columns + gaps + horizontal padding */
  .grid-scale-host {
    --grid-intrinsic-width: 938px;
    container-type: inline-size;
    container-name: discount-grid;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .grid-container {
    --grid-scale: min(1, calc((100cqi - 1.5rem) / var(--grid-intrinsic-width)));
    --module-col: calc(100px * var(--grid-scale));
    --grid-sidebar-col: calc(34px * var(--grid-scale));
    --grid-divider-col: calc(13px * var(--grid-scale));
    --grid-col-gap: calc(7px * var(--grid-scale));
    --grid-row-gap: calc(13px * var(--grid-scale));
    --grid-padding: calc(14px * var(--grid-scale));
    --module-icon-max-height: calc(80px * var(--grid-scale));
    --module-name-strip: calc(29px * var(--grid-scale));
    --module-card-padding: calc(5px * var(--grid-scale));
    --module-card-padding-x: calc(7px * var(--grid-scale));
    --module-card-radius: calc(8px * var(--grid-scale));
    --module-name-font: calc(13.6px * var(--grid-scale));
    --footer-icon-size: calc(11px * var(--grid-scale));
    --grid-header-height: calc(40px * var(--grid-scale));
    --grid-header-font: calc(13.6px * var(--grid-scale));
    --grid-header-icon: calc(20px * var(--grid-scale));
    --sidebar-label-letter-spacing: calc(0.02em * var(--grid-scale));
    /* Upright stack: ~6 letters tall + narrow column */
    --sidebar-label-font-size: min(
      calc(var(--module-cell-height) / 10),
      calc(var(--grid-sidebar-col) * 0.68)
    );
    --module-card-height: calc(
      var(--module-icon-max-height) + 2 * var(--module-card-padding) + var(--module-name-strip)
    );
    --module-cell-height: var(--module-card-height);
    display: grid;
    grid-template-columns:
      var(--grid-sidebar-col)
      repeat(4, var(--module-col))
      var(--grid-divider-col)
      repeat(4, var(--module-col));
    grid-template-rows: auto;
    grid-auto-rows: var(--module-cell-height);
    column-gap: var(--grid-col-gap);
    row-gap: var(--grid-row-gap);
    background: #15181e;
    padding: var(--grid-padding);
    border-radius: calc(12px * var(--grid-scale));
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    width: fit-content;
    max-width: 100%;
    margin-inline: auto;
    box-sizing: border-box;
  }

  @supports not (container-type: inline-size) {
    .grid-container {
      --grid-scale: min(1, calc((100vw - 4.5rem) / var(--grid-intrinsic-width)));
    }
  }

  @container discount-grid (max-width: 480px) {
    .grid-container {
      --sidebar-label-font-size: min(
        calc(var(--module-cell-height) / 11),
        calc(var(--grid-sidebar-col) * 0.62)
      );
      --sidebar-label-letter-spacing: 0;
    }
  }

</style>

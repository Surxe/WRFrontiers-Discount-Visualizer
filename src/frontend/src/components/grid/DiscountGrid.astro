---
import GridHeader from './GridHeader.astro';
import DiscountGridRow from './DiscountGridRow.astro';
import {
  isTitan,
  categorize,
  processBots,
  getWeaponAndGear,
  countStandardRows,
  countTitanRows,
} from '../../utils/gridData.js';

const { items, shopCards, catIcons } = Astro.props;

const standardItems = items.filter((i) => !isTitan(i));
const titanItems = items.filter((i) => isTitan(i));

const standardBots = processBots(standardItems);
const titanBots = processBots(titanItems);
const stdWeapons = getWeaponAndGear(standardItems);
const titanWeapons = titanItems.filter((i) => categorize(i) === null);

const stdRows = countStandardRows(standardBots, stdWeapons);
const titanRows = countTitanRows(titanBots, titanWeapons);
---

<div class="grid-container">
  <GridHeader catIcons={catIcons} />

  {Array.from({ length: stdRows }).map((_, i) => (
    <DiscountGridRow
      bot={standardBots[i]}
      lightWep={stdWeapons.lightWep[i]}
      heavyWep={stdWeapons.heavyWep[i]}
      supply={stdWeapons.supply[i]}
      cycle={stdWeapons.cycle[i]}
      shopCards={shopCards}
      variant="standard"
    />
  ))}

  {titanItems.length > 0 && (
    <div class="titan-divider">
      <h2>Titan Discounts</h2>
    </div>
  )}

  {titanItems.length > 0 &&
    Array.from({ length: titanRows }).map((_, i) => (
      <DiscountGridRow
        bot={titanBots[i]}
        titanWeapon={titanWeapons[i]}
        shopCards={shopCards}
        variant="titan"
      />
    ))}
</div>

<style>
  .grid-container {
    --module-cell-height: 120px;
    --module-name-strip: 32px;
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    grid-auto-rows: minmax(var(--module-cell-height), auto);
    gap: 8px;
    background: #15181e;
    padding: 24px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }

  .titan-divider {
    grid-column: 1 / -1;
    margin-top: 32px;
    margin-bottom: 16px;
    text-align: center;
    border-top: 2px solid #333;
    padding-top: 24px;
  }

  .titan-divider h2 {
    margin: 0;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 2px;
  }
</style>

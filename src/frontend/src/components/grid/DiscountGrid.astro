---
import GridHeader from './GridHeader.astro';
import DiscountGridRow from './DiscountGridRow.astro';
import {
  isTitan,
  categorize,
  processBots,
  getWeaponAndGear,
  assignWeaponTypeToBots,
  countStandardRows,
  countTitanRows,
} from '../../utils/gridData.js';

const { items, shopCards, catIcons } = Astro.props;

const standardItems = items.filter((i) => !isTitan(i));
const titanItems = items.filter((i) => isTitan(i));

const standardBots = processBots(standardItems);
const titanBots = processBots(titanItems);
const stdWeapons = getWeaponAndGear(standardItems);
const titanWeapons = titanItems.filter((i) => categorize(i) === null);

// Assign weapons to their preferred bot rows
const assignedLightWep = assignWeaponTypeToBots(standardBots, stdWeapons.lightWep);
const assignedHeavyWep = assignWeaponTypeToBots(standardBots, stdWeapons.heavyWep);
const assignedSupply = assignWeaponTypeToBots(standardBots, stdWeapons.supply);
const assignedCycle = assignWeaponTypeToBots(standardBots, stdWeapons.cycle);
const assignedTitanWeapons = assignWeaponTypeToBots(titanBots, titanWeapons);

const stdRows = countStandardRows(standardBots, stdWeapons);
const titanRows = countTitanRows(titanBots, titanWeapons);
---

<div class="grid-container">
  <GridHeader catIcons={catIcons} />

  {Array.from({ length: stdRows }).map((_, i) => (
    <DiscountGridRow
      bot={standardBots[i]}
      lightWep={assignedLightWep[i]}
      heavyWep={assignedHeavyWep[i]}
      supply={assignedSupply[i]}
      cycle={assignedCycle[i]}
      shopCards={shopCards}
      variant="standard"
      sidebarLabel={i === Math.floor((stdRows - 1) / 2) ? 'Mechs' : null}
    />
  ))}

  {titanItems.length > 0 && (
    <>
      {Array.from({ length: titanRows }).map((_, i) => (
        <DiscountGridRow
          bot={titanBots[i]}
          titanWeapon={assignedTitanWeapons[i]}
          shopCards={shopCards}
          variant="titan"
          sidebarLabel={i === 0 ? 'Titans' : null}
        />
      ))}
    </>
  )}
</div>

<style>
  .grid-container {
    --module-icon-max-height: 88px;
    --module-name-strip: 32px;
    --module-card-padding: 6px;
    --module-card-padding-x: 8px;
    --module-card-height: calc(
      var(--module-icon-max-height) + 2 * var(--module-card-padding) + var(--module-name-strip)
    );
    --module-cell-height: var(--module-card-height);
    display: grid;
    grid-template-columns: 40px repeat(4, 1fr) 16px repeat(4, 1fr);
    grid-template-rows: auto;
    grid-auto-rows: minmax(var(--module-cell-height), auto);
    gap: 8px;
    background: #15181e;
    padding: 16px;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  }
</style>

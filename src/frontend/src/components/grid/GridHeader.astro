---
import { getTexturePath } from '../../utils/textures.js';

const { catIcons } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const icon = (path) => getTexturePath(path, baseUrl);
---

<div class="grid-header bot-col">
  {catIcons?.torso && <img src={icon(catIcons.torso)} class="header-icon" alt="" />}
  Torso
</div>
<div class="grid-header bot-col">
  {catIcons?.shoulder && <img src={icon(catIcons.shoulder)} class="header-icon" alt="" />}
  Shoulder
</div>
<div class="grid-header bot-col">
  {catIcons?.chassis && <img src={icon(catIcons.chassis)} class="header-icon" alt="" />}
  Chassis
</div>
<div class="grid-header">
  {catIcons?.weapon && <img src={icon(catIcons.weapon)} class="header-icon" alt="" />}
  Light Wep
</div>
<div class="grid-header">
  {catIcons?.weapon && <img src={icon(catIcons.weapon)} class="header-icon" alt="" />}
  Heavy Wep
</div>
<div class="grid-header">
  {catIcons?.ability && <img src={icon(catIcons.ability)} class="header-icon" alt="" />}
  Supply Gear
</div>
<div class="grid-header">
  {catIcons?.ability && <img src={icon(catIcons.ability)} class="header-icon" alt="" />}
  Cycle Gear
</div>

<style>
  .grid-header {
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 0.85rem;
    color: #7b8390;
    text-align: center;
    padding-bottom: 8px;
    border-bottom: 2px solid #232730;
    height: 40px;
  }

  .header-icon {
    width: 20px;
    height: 20px;
    margin-right: 6px;
    object-fit: contain;
  }
</style>

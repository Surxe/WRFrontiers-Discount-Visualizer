---
import { getTexturePath } from '../../utils/textures.js';

const { catIcons } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const icon = (path) => getTexturePath(path, baseUrl);
---

<div class="grid-header sidebar-header"></div>
<div class="grid-header bot-col">
  <span class="header-label">Bot</span>
</div>
<div class="grid-header bot-col">
  {catIcons?.[1] && <img src={icon(catIcons[1])} class="header-icon" alt="" />}
  <span class="header-label">Torso</span>
</div>
<div class="grid-header bot-col">
  {catIcons?.[2] && <img src={icon(catIcons[2])} class="header-icon" alt="" />}
  <span class="header-label">Shoulder</span>
</div>
<div class="grid-header bot-col">
  {catIcons?.[3] && <img src={icon(catIcons[3])} class="header-icon" alt="" />}
  <span class="header-label">Chassis</span>
</div>
<div class="grid-spacer"></div>
<div class="grid-header">
  {catIcons?.[4] && <img src={icon(catIcons[4])} class="header-icon" alt="" />}
  <span class="header-label">Light Wep</span>
</div>
<div class="grid-header">
  {catIcons?.[5] && <img src={icon(catIcons[5])} class="header-icon" alt="" />}
  <span class="header-label">Heavy Wep</span>
</div>
<div class="grid-header">
  {catIcons?.[6] && <img src={icon(catIcons[6])} class="header-icon" alt="" />}
  <span class="header-label">Supply Gear</span>
</div>
<div class="grid-header">
  {catIcons?.[7] && <img src={icon(catIcons[7])} class="header-icon" alt="" />}
  <span class="header-label">Cycle Gear</span>
</div>

<style>
  .grid-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    gap: calc(3 * var(--grid-scale-unit, 1px));
    text-transform: uppercase;
    font-weight: 800;
    font-size: var(--grid-header-font, 0.85rem);
    color: #7b8390;
    text-align: center;
    padding-bottom: calc(6 * var(--grid-scale-unit, 1px));
    border-bottom: calc(2 * var(--grid-scale-unit, 1px)) solid #232730;
    min-height: var(--grid-header-height, 60px);
    box-sizing: border-box;
  }

  .header-icon {
    display: block;
    width: var(--grid-header-icon, 30px);
    height: var(--grid-header-icon, 30px);
    object-fit: contain;
    flex-shrink: 0;
  }

  .header-label {
    display: block;
    line-height: 1.1;
  }

  .sidebar-header {
    visibility: hidden;
  }
</style>

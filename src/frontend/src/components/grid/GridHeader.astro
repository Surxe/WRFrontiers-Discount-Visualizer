---
import { getTexturePath } from '../../utils/textures.js';

const { catIcons } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const icon = (path) => getTexturePath(path, baseUrl);
---

<div class="grid-header sidebar-header"></div>
<div class="grid-header bot-col">
  Bot
</div>
<div class="grid-header bot-col">
  {catIcons?.torso && <img src={icon(catIcons.torso)} class="header-icon" alt="" />}
  Torso
</div>
<div class="grid-header bot-col">
  {catIcons?.shoulder && <img src={icon(catIcons.shoulder)} class="header-icon" alt="" />}
  Shoulder
</div>
<div class="grid-header bot-col">
  {catIcons?.chassis && <img src={icon(catIcons.chassis)} class="header-icon" alt="" />}
  Chassis
</div>
<div class="grid-spacer"></div>
<div class="grid-header">
  {catIcons?.lightWep && <img src={icon(catIcons.lightWep)} class="header-icon" alt="" />}
  Light Wep
</div>
<div class="grid-header">
  {catIcons?.heavyWep && <img src={icon(catIcons.heavyWep)} class="header-icon" alt="" />}
  Heavy Wep
</div>
<div class="grid-header">
  {catIcons?.supplyGear && <img src={icon(catIcons.supplyGear)} class="header-icon" alt="" />}
  Supply Gear
</div>
<div class="grid-header">
  {catIcons?.cycleGear && <img src={icon(catIcons.cycleGear)} class="header-icon" alt="" />}
  Cycle Gear
</div>

<style>
  .grid-header {
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: uppercase;
    font-weight: 800;
    font-size: var(--grid-header-font, 0.85rem);
    color: #7b8390;
    text-align: center;
    padding-bottom: calc(8px * var(--grid-scale, 1));
    border-bottom: calc(2px * var(--grid-scale, 1)) solid #232730;
    height: var(--grid-header-height, 40px);
  }

  .header-icon {
    width: var(--grid-header-icon, 20px);
    height: var(--grid-header-icon, 20px);
    margin-right: calc(6px * var(--grid-scale, 1));
    object-fit: contain;
  }

  .sidebar-header {
    visibility: hidden;
  }
</style>

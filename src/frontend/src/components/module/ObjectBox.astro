---
import '../../styles/module-icon.css';
import '../../styles/module-card.css';
import { getTexturePath, getRarityBackgroundUrl } from '../../utils/textures.js';

const { module, shopCards, showName = true, showBadges = false, style: inlineStyle, disableBackground = false, lastDiscountDate = null, category = null } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const iconSrc = getTexturePath(module.icon_path, baseUrl);
const backgroundUrl = disableBackground ? null : getRarityBackgroundUrl(module.rarity, shopCards, baseUrl);
const bgStyle = backgroundUrl ? `background-image: url('${backgroundUrl}');` : '';

const factionIconSrc = module.faction_icon_path
  ? getTexturePath(module.faction_icon_path, baseUrl)
  : null;
const classIconSrc = module.class_icon_path
  ? getTexturePath(module.class_icon_path, baseUrl)
  : null;

const hasFooterIcons = showBadges && (factionIconSrc || classIconSrc);

const href = category ? `${baseUrl}items?group=${category}` : null;
---

{href ? (
  <a href={href} class="object-box-link" style={inlineStyle}>
    <div class="object-box">
      <div
        class:list={['module-card', 'object-box__card', { 'object-box__card--no-name': !showName }]}
        style={bgStyle || undefined}
      >
        <div class="module-card__icon">
          {iconSrc && <img class="module-icon" src={iconSrc} alt={module.name} />}
        </div>
        {showName && (
          <div class="module-card__footer">
            <span class="module-card__name">{module.name}</span>
            {hasFooterIcons && (
              <div class="module-card__footer-icons">
                {factionIconSrc && (
                  <img
                    class="module-card__footer-icon"
                    src={factionIconSrc}
                    alt=""
                    title="Faction"
                  />
                )}
                {classIconSrc && (
                  <img
                    class="module-card__footer-icon"
                    src={classIconSrc}
                    alt=""
                    title="Class"
                  />
                )}
              </div>
            )}
          </div>
        )}
      </div>
      <div class="object-box__tooltip">
        {lastDiscountDate ? (
          <>
            {module.name}<br />
            <span class="tooltip-date">Last Discount: {lastDiscountDate}</span>
          </>
        ) : (
          module.name
        )}
      </div>
    </div>
  </a>
) : (
  <div class="object-box" style={inlineStyle}>
    <div
      class:list={['module-card', 'object-box__card', { 'object-box__card--no-name': !showName }]}
      style={bgStyle || undefined}
    >
      <div class="module-card__icon">
        {iconSrc && <img class="module-icon" src={iconSrc} alt={module.name} />}
      </div>
      {showName && (
        <div class="module-card__footer">
          <span class="module-card__name">{module.name}</span>
          {hasFooterIcons && (
            <div class="module-card__footer-icons">
              {factionIconSrc && (
                <img
                  class="module-card__footer-icon"
                  src={factionIconSrc}
                  alt=""
                  title="Faction"
                />
              )}
              {classIconSrc && (
                <img
                  class="module-card__footer-icon"
                  src={classIconSrc}
                  alt=""
                  title="Class"
                />
              )}
            </div>
          )}
        </div>
      )}
    </div>
    <div class="object-box__tooltip">
      {lastDiscountDate ? (
        <>
          {module.name}<br />
          <span class="tooltip-date">Last Discount: {lastDiscountDate}</span>
        </>
      ) : (
        module.name
      )}
    </div>
  </div>
)}

<style>
  .object-box-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    border-bottom: none;
    position: relative;
  }

  .object-box {
    display: block;
    width: 100%;
    height: 100%;
    text-align: center;
    overflow: visible;
    position: relative;
  }

  .object-box__card {
    display: flex;
    flex-direction: column;
    transition: transform 0.2s;
  }

  .object-box-link:hover .object-box__card,
  .object-box:hover .object-box__card {
    transform: translateY(-2px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
  }

  .object-box__tooltip {
    position: absolute;
    left: 50%;
    top: calc(100% + 10px);
    transform: translateX(-50%) translateY(-6px);
    width: calc(100% - 16px);
    opacity: 0;
    pointer-events: none;
    white-space: normal;
    background: rgba(20, 20, 20, 0.95);
    color: #fff;
    padding: 8px 12px;
    border-radius: 999px;
    font-size: 0.78rem;
    line-height: 1.3;
    text-align: center;
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.25);
    transition: opacity 0.18s ease, transform 0.18s ease;
    z-index: 2;
    max-width: none;
    overflow-wrap: anywhere;
  }

  .object-box-link:hover .object-box__tooltip,
  .object-box:hover .object-box__tooltip {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .object-box__card .module-card__icon {
    flex: 1;
    min-height: 0;
  }

  .object-box__card--no-name .module-card__icon {
    display: flex !important;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .object-box__card .module-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: calc(6px * var(--grid-scale, 1));
    flex-shrink: 0;
    padding: calc(1px * var(--grid-scale, 1)) calc(8px * var(--grid-scale, 1));
  }

  .object-box__card .module-card__name {
    flex: 1;
    min-width: 0;
    text-align: left;
    background: none;
    border-top: none;
    padding: 0;
    min-height: 0;
    line-height: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .module-card__footer-icons {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    gap: calc(1px * var(--grid-scale, 1));
    flex-shrink: 0;
  }

  .module-card__footer-icon {
    display: block;
    width: var(--footer-icon-size, 11px);
    height: var(--footer-icon-size, 11px);
    object-fit: contain;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.6));
  }

  .object-box__tooltip .tooltip-date {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9em;
    margin-top: 2px;
  }
</style>

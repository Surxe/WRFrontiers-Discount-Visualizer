---
import '../../styles/module-icon.css';
import '../../styles/module-card.css';
import ObjectBox from './ObjectBox.astro';
import { getRarityBackgroundUrl } from '../../utils/textures.js';

const { modules = [], shopCards } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const firstNonNullModule = modules.find(m => m != null);

// Use rarity from first module for the shared background
const backgroundUrl = firstNonNullModule
  ? getRarityBackgroundUrl(firstNonNullModule.rarity, shopCards, baseUrl)
  : null;
const bgStyle = backgroundUrl ? `background-image: url('${backgroundUrl}');` : '';
---

<div class="modules-box" style={bgStyle || undefined}>
  {modules.map((module) => (
    module ? (
      <ObjectBox 
        module={module} 
        shopCards={shopCards} 
        showName={false} 
        disableBackground={true} 
        lastDiscountDate={module.lastDiscountDate} 
      />
    ) : (
      <div class="object-box empty-slot" style="flex: 1;"></div>
    )
  ))}
</div>

<style>
  .modules-box {
    display: flex;
    gap: 0;
    background-size: cover;
    background-position: left center;
    background-repeat: no-repeat;
    border-radius: var(--module-card-radius, 8px);
    overflow: visible;
    grid-column: span 3;
    min-width: 0;
    min-height: 0;
  }

  .modules-box :global(.object-box) {
    flex: 1;
  }

  .modules-box :global(.module-card) {
    background: none !important;
  }
</style>

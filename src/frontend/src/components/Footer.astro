---
import DiscordFeedback from './DiscordFeedback.astro';
import GitHubHistory from './GitHubHistory.astro';
import RobotsLink from './RobotsLink.astro';

const { baseUrl = '/WRFrontiers-Discount-Visualizer/' } = Astro.props;
---

<div class="page-footer">
	<div class="footer-links">
		<DiscordFeedback />
		<GitHubHistory />
		<RobotsLink />
	</div>
	<div class="legal-links">
		<a href={`${baseUrl}terms-of-service`} class="legal-link">Terms of Service</a>
		<span class="legal-separator">|</span>
		<a href={`${baseUrl}privacy-policy`} class="legal-link">Privacy Policy</a>
	</div>
</div>

<style>
	.page-footer {
		flex-shrink: 0;
		padding-top: 2rem;
		padding-bottom: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.legal-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
		font-size: 0.875rem;
	}

	.legal-link {
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.2s;
	}

	.legal-link:hover {
		color: var(--accent-color);
	}

	.legal-separator {
		color: var(--text-muted);
		opacity: 0.5;
	}
</style>

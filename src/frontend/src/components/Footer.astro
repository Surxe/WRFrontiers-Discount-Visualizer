---
import DiscordFeedback from './DiscordFeedback.astro';
import GitHubHistory from './GitHubHistory.astro';
import RobotsLink from './RobotsLink.astro';
import LegalDisclaimer from './LegalDisclaimer.astro';
---

<div class="page-footer">
	<div class="footer-links">
		<DiscordFeedback />
		<GitHubHistory />
		<RobotsLink />
	</div>
	<LegalDisclaimer />
</div>

<style>
	.page-footer {
		flex-shrink: 0;
		padding-top: 2rem;
		padding-bottom: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-links {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}
</style>

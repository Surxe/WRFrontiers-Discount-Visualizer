---
import { getTexturePath } from '../utils/textures.js';

interface Props {
	title: string;
	timelineData: Array<{
		week: string;
		items: Array<{
			id: string;
			name: string;
			iconPath: string;
		}>;
	}>;
	baseUrl: string;
}

const { title, timelineData, baseUrl } = Astro.props;
let lastYear: string | null = null;
---

{timelineData.length > 0 && (
	<div class="timeline-section">
		<h2>{title}</h2>
		<div class="timeline">
			{(() => {
				// Reset lastYear state for this rendering pass
				lastYear = null;
				return timelineData.map(({ week, items }) => {
					const year = week.split('-')[0];
					const showYearHeader = year !== lastYear;
					lastYear = year;
					const dateObj = new Date(week);
					const monthDay = dateObj.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
					
					return (
						<>
							{showYearHeader && (
								<div class="timeline-year-header">{year}</div>
							)}
							<div class="timeline-column">
								<a href={`${baseUrl}week/${week}`} class="timeline-week-link">
									<span class="timeline-week">{monthDay}</span>
								</a>
								<div class="timeline-icons">
									{items.map(item => (
										<a 
											href={`${baseUrl}week/${week}`} 
											class="timeline-icon"
											title={item.name}
										>
											<img 
												src={getTexturePath(item.iconPath, baseUrl)} 
												alt={item.name}
											/>
											<span class="timeline-icon-name">{item.name}</span>
										</a>
									))}
								</div>
							</div>
						</>
					);
				});
			})()}
		</div>
	</div>
)}

<style>
	.timeline-section {
		margin-top: 2rem;
		margin-bottom: 2rem;
		padding: 1.5rem;
		background-color: var(--sidebar-bg, #161920);
		border: 1px solid var(--sidebar-border, #232733);
		border-radius: 0.5rem;
	}

	.timeline-section h2 {
		font-size: 1.5rem;
		margin-top: 0;
		margin-bottom: 1.5rem;
		color: var(--text-color, #e0e0e0);
		border-bottom: 1px solid var(--sidebar-border, #232733);
		padding-bottom: 0.5rem;
	}

	.timeline {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: 1.5rem;
	}

	.timeline-year-header {
		width: 100%;
		font-size: 1rem;
		font-weight: 700;
		color: var(--accent-color, #3a86ff);
		margin-top: 1rem;
		margin-bottom: 0.5rem;
		padding-bottom: 0.25rem;
		border-bottom: 2px solid var(--accent-color, #3a86ff);
	}

	.timeline-year-header:first-child {
		margin-top: 0;
	}

	.timeline-column {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		min-width: 90px;
	}

	.timeline-week-link {
		text-decoration: none;
		border-bottom: 1px dotted var(--text-muted, #8b92a5);
		transition: border-color 0.2s, color 0.2s;
	}

	.timeline-week-link:hover {
		border-bottom-color: var(--accent-color, #3a86ff);
	}

	.timeline-week {
		font-size: 0.875rem;
		color: var(--accent-color, #3a86ff);
		font-weight: 600;
		text-align: center;
		transition: color 0.2s;
	}

	.timeline-week-link:hover .timeline-week {
		color: var(--accent-hover, #2b65cc);
	}

	.timeline-icons {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
		min-height: 80px;
	}

	.timeline-icon {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-decoration: none;
		transition: transform 0.2s;
	}

	.timeline-icon:hover {
		transform: translateY(-2px);
	}

	.timeline-icon img {
		width: 56px;
		height: 56px;
		object-fit: contain;
		border-radius: 0.25rem;
		background-color: var(--sidebar-bg, #161920);
		border: 1px solid var(--sidebar-border, #232733);
		padding: 2px;
	}

	.timeline-icon-name {
		font-size: 0.65rem;
		color: var(--text-secondary, #888);
		margin-top: 0.25rem;
		text-align: center;
		max-width: 70px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	@media (max-width: 768px) {
		.timeline-section {
			padding: 1rem;
		}

		.timeline-section h2 {
			font-size: 1.25rem;
		}

		.timeline-year-header {
			font-size: 0.875rem;
		}

		.timeline {
			gap: 1rem;
		}

		.timeline-column {
			min-width: 70px;
		}

		.timeline-week {
			font-size: 0.75rem;
		}

		.timeline-icons {
			gap: 0.5rem;
		}

		.timeline-icon img {
			width: 42px;
			height: 42px;
		}

		.timeline-icon-name {
			font-size: 0.55rem;
			max-width: 60px;
		}
	}
</style>
